<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Slide rasterization for Unchained.Pptx.
    Depends on Unchained.Pptx + Unchained.Pptx.Runtimes + HarfBuzzSharp.
    Implementation is deferred — this scaffold exists so the solution compiles
    and the package dependency chain is established.
  -->

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PackageTags>pptx;powerpoint;presentation;rendering;dotnet;csharp;document-processing</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Unchained.Pptx\Unchained.Pptx.csproj" />
    <ProjectReference Include="..\Unchained.Pptx.Runtimes\Unchained.Pptx.Runtimes.csproj" />
  </ItemGroup>

</Project>
