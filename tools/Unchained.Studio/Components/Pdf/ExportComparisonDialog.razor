@using Unchained.Pdf.Abstractions
@inject RenderingService Renderer
@inject PdfiumReferenceRenderer Pdfium
@inject FileExportService Exporter
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Outlined.CompareArrows" Class="mr-2" Style="vertical-align:middle;"/>
            Export Comparison Images
        </MudText>
    </TitleContent>

    <DialogContent>
        @if (_exporting)
        {
            <!-- Progress view -->
            <div style="min-width:400px;">
                <MudText Typo="Typo.body2" Class="mb-2">
                    @_progressMessage
                </MudText>
                <MudProgressLinear Value="_progressPercent" Color="Color.Primary" Rounded="true" Class="mb-1"/>
                <MudText Typo="Typo.caption" Style="opacity:.6;">
                    @_progressDetail
                </MudText>

                @if (_errors.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                        @_errors.Count page(s) failed to render — skipped.
                    </MudAlert>
                }
            </div>
        }
        else
        {
            <MudStack Style="min-width:420px;" Spacing="4">
                <!-- Page selection -->
                <div>
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Pages</MudText>
                    <MudRadioGroup @bind-Value="_pageMode" T="PageMode">
                        <MudRadio Value="PageMode.Current" Color="Color.Primary">
                            Current page (@CurrentPage)
                        </MudRadio>
                        <MudRadio Value="PageMode.All" Color="Color.Primary">
                            All pages (@PageCount total)
                        </MudRadio>
                        <MudRadio Value="PageMode.Range" Color="Color.Primary">Custom range</MudRadio>
                    </MudRadioGroup>
                    @if (_pageMode == PageMode.Range)
                    {
                        <MudTextField @bind-Value="_rangeText"
                                      Label="Page range"
                                      HelperText="Examples: 1,3,5-8  or  2-5  or  1,4,7"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="mt-1"
                                      Error="@(_rangeError is not null)"
                                      ErrorText="@_rangeError"/>
                    }
                </div>

                <!-- Resolution -->
                <div>
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Resolution</MudText>
                    <MudSelect T="int" @bind-Value="_dpi"
                               Label="DPI (both renderers)"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Style="width:160px;">
                        <MudSelectItem Value="72">72 DPI — fast</MudSelectItem>
                        <MudSelectItem Value="96">96 DPI — screen</MudSelectItem>
                        <MudSelectItem Value="150">150 DPI — balanced</MudSelectItem>
                        <MudSelectItem Value="300">300 DPI — print quality</MudSelectItem>
                    </MudSelect>
                </div>

                <!-- Output format -->
                <div>
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Output</MudText>
                    <MudRadioGroup @bind-Value="_outputMode" T="OutputMode">
                        <MudRadio Value="OutputMode.Zip" Color="Color.Primary">
                            Download as ZIP
                            <MudText Typo="Typo.caption" Style="opacity:.6;display:block;">
                                Single ZIP containing unchained/ and pdfium/ subfolders
                            </MudText>
                        </MudRadio>
                    </MudRadioGroup>
                </div>

                <!-- File naming preview -->
                <MudPaper Elevation="0" Class="pa-3" Style="background:#f5f5f5;border-radius:6px;">
                    <MudText Typo="Typo.caption" Style="font-family:monospace;line-height:1.8;">
                        @FileNamePreview
                    </MudText>
                </MudPaper>
            </MudStack>
        }
    </DialogContent>

    <DialogActions>
        @if (_exporting)
        {
            <MudButton OnClick="Cancel" Color="Color.Error" Variant="Variant.Text">Cancel</MudButton>
        }
        else
        {
            <MudButton OnClick="Close" Variant="Variant.Text">Cancel</MudButton>
            <MudButton OnClick="StartExport"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Disabled="@(_rangeError is not null && _pageMode == PageMode.Range)"
                       StartIcon="@Icons.Material.Outlined.FileDownload">
                Export
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@* ReSharper disable once RedundantNameQualifier *@

@code {

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public IPdfDocument Document { get; set; } = null!;

    [Parameter]
    public byte[] DocumentBytes { get; set; } = null!;

    [Parameter]
    public string FileName { get; set; } = "document";

    [Parameter]
    public int CurrentPage { get; set; } = 1;

    [Parameter]
    public int PageCount { get; set; } = 1;

    private PageMode _pageMode = PageMode.Current;
    private OutputMode _outputMode = OutputMode.Zip;
    private string _rangeText = string.Empty;
    private string? _rangeError;
    private int _dpi = 96;

    private bool _exporting;
    private string _progressMessage = string.Empty;
    private string _progressDetail = string.Empty;
    private double _progressPercent;
    private readonly List<string> _errors = [];
    private CancellationTokenSource? _cts;

    private string FileNamePreview => BuildFileNamePreview();

    private string BuildFileNamePreview()
    {
        var baseName = Path.GetFileNameWithoutExtension(FileName);
        return $"{baseName}_comparison_{_dpi}dpi.zip\n  └ unchained/page_001.png\n  └ pdfium/page_001.png\n  └ …";
    }

    private void Close() => MudDialog.Cancel();

    private void Cancel() => _cts?.Cancel();

    private async Task StartExport()
    {
        var pages = ResolvePages();
        if (pages is null) return;

        _exporting = true;
        _errors.Clear();
        _progressPercent = 0;
        _cts = new CancellationTokenSource();
        var ct = _cts.Token;

        try
        {
            var baseName = Path.GetFileNameWithoutExtension(FileName);
            var collected = new List<(string Name, byte[] Bytes)>();
            var done = 0;

            foreach (var page in pages.TakeWhile(_ => !ct.IsCancellationRequested))
            {
                _progressMessage = $"Rendering page {page} of {pages.Count}…";
                _progressDetail = string.Empty;
                StateHasChanged();

                // ── Unchained render (server-side, 30 s cap) ───────────────
                byte[]? unchainedBytes = null;
                using (var uts = CancellationTokenSource.CreateLinkedTokenSource(ct))
                {
                    uts.CancelAfter(TimeSpan.FromSeconds(30));
                    try
                    {
                        _progressDetail = "Unchained (FreeType2)…";
                        StateHasChanged();
                        unchainedBytes = await Renderer.RenderPdfPageAsync(Document, page, _dpi, uts.Token);
                    }
                    catch (OperationCanceledException)
                    {
                        _errors.Add($"p.{page} Unchained: timeout (>30 s)");
                    }
                    catch (Exception ex)
                    {
                        _errors.Add($"p.{page} Unchained: {ex.Message}");
                    }
                }

                // ── Pdfium reference render (server-side, same engine as Chrome, 30 s cap) ──
                byte[]? pdfiumBytes = null;
                using (var pts = CancellationTokenSource.CreateLinkedTokenSource(ct))
                {
                    pts.CancelAfter(TimeSpan.FromSeconds(30));
                    try
                    {
                        _progressDetail = "Pdfium (Chrome engine)…";
                        StateHasChanged();
                        pdfiumBytes = await Pdfium.RenderPageAsync(DocumentBytes, page, _dpi, pts.Token);
                        if (pdfiumBytes is null)
                            _errors.Add($"p.{page} Pdfium: render returned null");
                    }
                    catch (OperationCanceledException)
                    {
                        _errors.Add($"p.{page} Pdfium: timeout (>30 s)");
                    }
                    catch (Exception ex)
                    {
                        _errors.Add($"p.{page} Pdfium: {ex.Message}");
                    }
                }

                // Collect results
                var pageTag = page.ToString("D3");
                if (unchainedBytes is not null)
                    collected.Add(($"unchained/page_{pageTag}.png", unchainedBytes));
                if (pdfiumBytes is not null)
                    collected.Add(($"pdfium/page_{pageTag}.png", pdfiumBytes));

                done++;
                _progressPercent = done * 100.0 / pages.Count;
                StateHasChanged();
            }

            if (ct.IsCancellationRequested)
            {
                _progressMessage = "Export cancelled.";
                StateHasChanged();
                await Task.Delay(1200, ct);
                MudDialog.Cancel();
                return;
            }

            if (collected.Count == 0)
            {
                Snackbar.Add("Nothing was exported — all pages failed to render.", Severity.Warning);
                _exporting = false;
                StateHasChanged();
                return;
            }

            // ── Save ────────────────────────────────────────────────────────
            _progressMessage = "Saving files…";
            _progressDetail = string.Empty;
            StateHasChanged();

            if (_outputMode == OutputMode.Zip)
            {
                await SaveAsZip(collected, baseName);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        finally
        {
            _cts?.Dispose();
            _cts = null;
        }
    }

    private async Task SaveAsZip(IReadOnlyList<(string Name, byte[] Bytes)> files, string baseName)
    {
        var zipBytes = ZipBuilder.Build(files);
        await Exporter.TriggerDownloadAsync(
            zipBytes,
            $"{baseName}_comparison_{_dpi}dpi.zip",
            "application/zip"
        );
        Snackbar.Add($"ZIP with {files.Count} files downloaded.", Severity.Success);
    }

    // Parses the page selection and returns a validated, sorted, deduplicated list.
    private List<int>? ResolvePages()
    {
        _rangeError = null;

        return _pageMode switch
        {
            PageMode.Current => [CurrentPage],
            PageMode.All => Enumerable.Range(1, PageCount).ToList(),
            PageMode.Range => PageRangeParser.Parse(_rangeText, PageCount, out _rangeError),
            _ => [CurrentPage]
        };
    }

}
