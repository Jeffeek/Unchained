@page "/pdf"
@inject SessionStateService Session
@inject FileExportService Exporter
@inject IUserFeedback Feedback
@inject IStudioDialogs Dialogs
@using System.Text
@using Unchained.Pdf.Engine
@using Unchained.Pdf.Models
@using Unchained.Studio.Infrastructure
@implements IDisposable

<div class="studio-tab">
    @if (Session.Pdf is null)
    {
        <div class="drop-zone-page">
            <FileDropZone Title="Drop a PDF here"
                          Subtitle="Supports PDF 1.x–2.x, encrypted, linearized, tagged"
                          Accept=".pdf"
                          OnFileLoaded="LoadPdf"
                          OnError="Feedback.Error"/>
            @if (FeatureFlags.EnablePdfiumCompare)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Outlined.BatchPrediction"
                           OnClick="OpenBatchDialog"
                           Class="mt-3"
                           Style="align-self:center;">
                    Batch Compare…
                </MudButton>
            }
        </div>
    }
    else
    {
        var state = Session.Pdf;

        <div class="three-panel">
            <!-- LEFT: tree -->
            <div class="panel-tree">
                <DocumentTree Root="state.Tree"
                              SelectedNodeChanged="OnNodeSelected"
                              OnRefreshRequested="RefreshTree"/>
            </div>

            <!-- CENTRE: playboard -->
            <div class="panel-preview">
                <PdfPlayboard Document="state.Document"
                              DocumentBytes="state.CurrentBytes"
                              FileName="state.FileName"
                              CurrentPage="state.CurrentPage"
                              PageCount="state.Document.PageCount"
                              CurrentPageChanged="p => state.CurrentPage = p"
                              State="state.PlayboardState"
                              OnDirty="OnPlayboardDirty"/>

                <!-- Text extraction panel -->
                @if (_showTextPanel)
                {
                    <div class="text-panel">
                        <div class="text-panel-toolbar">
                            <MudText Typo="Typo.subtitle2">Extracted Text</MudText>
                            <MudSpacer/>
                            <MudIconButton Icon="@Icons.Material.Outlined.Download"
                                           Size="Size.Small"
                                           OnClick="DownloadText"
                                           title="Download as .txt"/>
                            <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                           Size="Size.Small"
                                           OnClick="() => _showTextPanel = false"/>
                        </div>
                        <textarea class="text-content" readonly>@_extractedText</textarea>
                    </div>
                }
            </div>

            <!-- RIGHT: properties -->
            <div class="panel-properties">
                <PropertiesPanel Bag="_selectedProperties"/>
            </div>
        </div>

        <!-- BOTTOM: operations bar -->
        <div class="operations-bar">
            <div class="ops-group">
                <MudButton StartIcon="@Icons.Material.Outlined.MergeType"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenMergeDialog">
                    Merge
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.CallSplit"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenSplitDialog">
                    Split
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Delete"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenRemovePagesDialog">
                    Remove pages
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.RotateRight"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="RotateCurrentPage">
                    Rotate
                </MudButton>
            </div>
            <MudDivider Vertical="true" Class="ops-divider"/>
            <div class="ops-group">
                <MudButton StartIcon="@Icons.Material.Outlined.Compress"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OptimizeDocument">
                    Optimize
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Lock"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenEncryptDialog">
                    Encrypt
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.BrandingWatermark"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenWatermarkDialog">
                    Watermark
                </MudButton>
            </div>
            <MudDivider Vertical="true" Class="ops-divider"/>
            <div class="ops-group">
                <MudButton StartIcon="@Icons.Material.Outlined.TextFields"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="ExtractText">
                    Extract text
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.VerifiedUser"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="ValidatePdfA">
                    Validate PDF/A
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Accessibility"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="ValidatePdfUA">
                    Validate PDF/UA
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Build"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="RepairDocument">
                    Repair
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Speed"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="LinearizeDocument">
                    Linearize
                </MudButton>
            </div>
            <MudDivider Vertical="true" Class="ops-divider"/>
            <div class="ops-group ops-group--right">
                @if (FeatureFlags.EnablePdfiumCompare)
                {
                    <MudButton StartIcon="@Icons.Material.Outlined.BatchPrediction"
                               Variant="Variant.Text" Size="Size.Small"
                               Color="Color.Secondary"
                               OnClick="OpenBatchDialog">
                        Batch Compare
                    </MudButton>
                }
                <MudDivider Vertical="true" Class="ops-divider"/>
                <MudButton StartIcon="@Icons.Material.Outlined.Download"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="DownloadDocument">
                    Download
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.FolderOpen"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenNewFile">
                    Open&hellip;
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Close"
                           Variant="Variant.Text" Size="Size.Small"
                           Color="Color.Error"
                           OnClick="CloseDocument">
                    Close
                </MudButton>
            </div>
        </div>
    }

    @if (_busy)
    {
        <div class="loading-overlay">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary"/>
            <MudText Typo="Typo.body1" Class="mt-3">@_busyMessage</MudText>
        </div>
    }
</div>

<!-- Hidden file input for "Open…" button -->
<InputFile id="pdf-open-input" OnChange="OnOpenFileSelected" accept=".pdf" style="display:none;"/>

@code {
    private PropertyBag? _selectedProperties;
    private bool _busy;
    private string _busyMessage = string.Empty;
    private bool _showTextPanel;
    private string? _extractedText;

    private BusyScope _busyScope = null!;

    protected override void OnInitialized() =>
        // Wire BusyScope to local state so Begin()/Dispose() work transparently.
        _busyScope = new BusyScope(msg =>
            {
                _busyMessage = msg ?? string.Empty;
                _busy = msg is not null;
                // Explicit StateHasChanged so the overlay appears/disappears immediately
                // without waiting for Blazor's automatic coalesced re-render.
                StateHasChanged();
            }
        );

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        // Subscribe to the Refreshed event so we re-render after any in-place mutation
        if (Session.Pdf is not null)
            Session.Pdf.Refreshed += OnSessionRefreshed;
    }

    private void OnSessionRefreshed() =>
        InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        if (Session.Pdf is not null)
            Session.Pdf.Refreshed -= OnSessionRefreshed;
    }

    // Reloads the session with new bytes, re-wiring the Refreshed subscription onto the
    // new PdfSessionState. Every reload-based operation (Optimize, Repair, Linearize, Merge,
    // Encrypt) must go through this — calling Session.LoadPdfAsync directly would leave the
    // Refreshed event bound to the disposed old session, so later in-place ops (Rotate,
    // Watermark, Remove) would stop re-rendering the tree.
    private async Task ReloadAsync(byte[] bytes, string fileName)
    {
        if (Session.Pdf is not null)
            Session.Pdf.Refreshed -= OnSessionRefreshed;

        await Session.LoadPdfAsync(bytes, fileName);

        if (Session.Pdf is not null)
            Session.Pdf.Refreshed += OnSessionRefreshed;
    }

    private async Task ReloadAsync(byte[] bytes, string fileName, string password)
    {
        if (Session.Pdf is not null)
            Session.Pdf.Refreshed -= OnSessionRefreshed;

        await Session.LoadPdfAsync(bytes, fileName, password);

        if (Session.Pdf is not null)
            Session.Pdf.Refreshed += OnSessionRefreshed;
    }

    private async Task LoadPdf((byte[] Bytes, string FileName) file)
    {
        try
        {
            using var _ = _busyScope.Begin("Loading PDF…");

            if (Session.Pdf is not null)
                Session.Pdf.Refreshed -= OnSessionRefreshed;

            await Session.LoadPdfAsync(file.Bytes, file.FileName);

            if (Session.Pdf is not null)
                Session.Pdf.Refreshed += OnSessionRefreshed;

            Feedback.Info($"Loaded {file.FileName}");
        }
        catch (Exception ex)
        {
            Feedback.Error($"Failed to load PDF: {ex.Message}");
        }
    }

    private void OnNodeSelected(TreeNode? node) =>
        _selectedProperties = node is null
            ? null
            : PdfPropertyAdapter.Build(node);

    private async Task RefreshTree()
    {
        if (Session.Pdf is null)
            return;

        using var _ = _busyScope.Begin("Refreshing…");
        await Session.Pdf.RefreshAsync();
    }

    private Task DownloadDocument() =>
        Session.Pdf is null
            ? Task.CompletedTask
            : Exporter.TriggerDownloadAsync(
                Session.Pdf.CurrentBytes,
                Session.Pdf.FileName,
                "application/pdf"
            );

    private void ExtractText()
    {
        if (Session.Pdf is null)
            return;

        using var _ = _busyScope.Begin("Extracting text…");
        var sb = new StringBuilder();
        for (var i = 1; i <= Session.Pdf.Document.PageCount; i++)
        {
            sb.AppendLine($"─── Page {i} ───");
            sb.AppendLine(Session.Pdf.Document.Pages[i].ExtractText());
            sb.AppendLine();
        }

        _extractedText = sb.ToString();
        _showTextPanel = true;
    }

    private async Task DownloadText()
    {
        if (_extractedText is null)
            return;

        try
        {
            await Exporter.TriggerDownloadAsync(
                Encoding.UTF8.GetBytes(_extractedText),
                Path.ChangeExtension(Session.Pdf?.FileName ?? "document", ".txt"),
                "text/plain"
            );
        }
        catch (Exception ex)
        {
            Feedback.Error($"Download failed: {ex.Message}");
        }
    }

    private async Task OptimizeDocument()
    {
        if (Session.Pdf is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Optimizing…");

            // Optimize via SaveOptions
            using var ms = new MemoryStream();
            var options = new SaveOptions(OptimizeSize: true);
            await Session.Pdf!.Processor.SaveAsync(Session.Pdf.Document, ms, options);
            var old = Session.Pdf.CurrentBytes.Length;
            await ReloadAsync(ms.ToArray(), Session.Pdf.FileName);
            var @new = Session.Pdf.CurrentBytes.Length;
            Feedback.Info($"Optimized: {old / 1024} KB → {@new / 1024} KB");
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task RepairDocument()
    {
        if (Session.Pdf is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Repairing…");

            var repaired = await Session.Pdf!.Processor.RepairAsync(Session.Pdf.CurrentBytes);
            using var ms = new MemoryStream();
            await Session.Pdf!.Processor.SaveAsync(repaired, ms);
            await repaired.DisposeAsync();
            await ReloadAsync(ms.ToArray(), Session.Pdf.FileName);
            Feedback.Info("Repair complete.");
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task LinearizeDocument()
    {
        if (Session.Pdf is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Linearizing…");

            using var ms = new MemoryStream();
            await Session.Pdf!.Processor.SaveAsync(
                Session.Pdf.Document,
                ms,
                SaveOptions.WebOptimized
            );
            await ReloadAsync(ms.ToArray(), Session.Pdf.FileName);
            Feedback.Info("Document linearized (web-optimized).");
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task ValidatePdfA()
    {
        if (Session.Pdf is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Validating PDF/A…");

            var result = await Session.Pdf!.Processor.ValidatePdfAAsync(Session.Pdf.CurrentBytes);
            var msg = result.IsConformant
                ? $"✅ PDF/A-1b conformant ({result.Violations.Count} violations)"
                : $"❌ Not conformant — {result.Violations.Count} violation(s): {result.Violations.FirstOrDefault()?.Description}";
            Feedback.Info(msg);
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task ValidatePdfUA()
    {
        if (Session.Pdf is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Validating PDF/UA…");

            var result = await Session.Pdf!.Processor.ValidatePdfUAAsync(Session.Pdf.CurrentBytes);
            var msg = result.IsConformant
                ? "✅ PDF/UA conformant"
                : $"❌ Not conformant — {result.Violations.Count} violation(s): {result.Violations.FirstOrDefault()?.Description}";
            Feedback.Info(msg);
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task RotateCurrentPage()
    {
        if (Session.Pdf is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Rotating page…");

            var page = Session.Pdf.CurrentPage;
            await new PageOrganizer().RotatePagesAsync(Session.Pdf.Document, [page], 90);
            await Session.Pdf.RefreshAsync();
            Feedback.Info($"Rotated page {page} by 90°.");
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private Task OpenBatchDialog() => Dialogs.ShowVoidAsync<BatchExportDialog>("Batch Comparison Export", fullWidth: false);

    private async Task OpenMergeDialog()
    {
        if (Session.Pdf is null)
            return;

        var extraDocs = await Dialogs.ShowAsync<MergeDialog, List<byte[]>>("Merge Documents");
        if (extraDocs is null || extraDocs.Count == 0)
            return;

        try
        {
            using var _ = _busyScope.Begin("Merging…");

            // Combine the current document's bytes with the uploaded ones, in order.
            var streams = new List<Stream> { new MemoryStream(Session.Pdf.CurrentBytes) };
            streams.AddRange(extraDocs.Select(static Stream (b) => new MemoryStream(b)));

            var merged = await new DocumentMerger().MergeAsync(streams, MergeOptions.Default);
            foreach (var s in streams) await s.DisposeAsync();

            using var ms = new MemoryStream();
            await Session.Pdf!.Processor.SaveAsync(merged, ms);
            await merged.DisposeAsync();

            await ReloadAsync(ms.ToArray(), Session.Pdf.FileName);
            Feedback.Info($"Merged {extraDocs.Count} document(s).");
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task OpenSplitDialog()
    {
        if (Session.Pdf is null)
            return;

        var ranges = await Dialogs.ShowAsync<SplitDialog, IReadOnlyList<(int Start, int End)>>(
            "Split Document",
            p => p[nameof(SplitDialog.PageCount)] = Session.Pdf!.Document.PageCount
        );
        if (ranges is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Splitting…");

            var parts = await new PageOrganizer().SplitAsync(Session.Pdf.Document, ranges);
            var zipEntries = new List<(string Name, byte[] Bytes)>();
            var baseName = Path.GetFileNameWithoutExtension(Session.Pdf.FileName);

            for (var i = 0; i < parts.Count; i++)
            {
                using var ms = new MemoryStream();
                await Session.Pdf!.Processor.SaveAsync(parts[i], ms);
                zipEntries.Add(($"{baseName}_part{i + 1}_p{ranges[i].Start}-{ranges[i].End}.pdf", ms.ToArray()));
                await parts[i].DisposeAsync();
            }

            await Exporter.TriggerDownloadAsync(ZipBuilder.Build(zipEntries), $"{baseName}_split.zip", "application/zip");
            Feedback.Info($"Split into {parts.Count} file(s) — downloaded as ZIP.");
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task OpenRemovePagesDialog()
    {
        if (Session.Pdf is null)
            return;

        var pages = await Dialogs.ShowAsync<RemovePagesDialog, List<int>>(
            "Remove Pages",
            p => p[nameof(RemovePagesDialog.PageCount)] = Session.Pdf!.Document.PageCount
        );
        if (pages is null || pages.Count == 0)
            return;

        try
        {
            using var _ = _busyScope.Begin("Removing pages…");

            await new PageOrganizer().DeletePagesAsync(Session.Pdf.Document, pages);
            await Session.Pdf.RefreshAsync();
            Feedback.Info($"Removed {pages.Count} page(s).");
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task OpenEncryptDialog()
    {
        if (Session.Pdf is null)
            return;

        var enc = await Dialogs.ShowAsync<EncryptDialog, EncryptResult>("Encrypt Document");
        if (enc is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Encrypting…");

            using var ms = new MemoryStream();
            await Session.Pdf!.Processor.ChangePasswordsAsync(
                Session.Pdf.Document,
                enc.UserPassword,
                enc.OwnerPassword,
                ms,
                enc.Algorithm
            );

            // Reload the re-encrypted bytes, using the new user password when one was set.
            var bytes = ms.ToArray();
            if (enc.UserPassword.Length > 0)
                await ReloadAsync(bytes, Session.Pdf.FileName, enc.UserPassword);
            else
                await ReloadAsync(bytes, Session.Pdf.FileName);

            Feedback.Info(
                enc.UserPassword.Length == 0 && enc.OwnerPassword.Length == 0
                    ? "Encryption removed."
                    : "Document encrypted."
            );
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task OpenWatermarkDialog()
    {
        if (Session.Pdf is null)
            return;

        var wm = await Dialogs.ShowAsync<WatermarkDialog, WatermarkResult>(
            "Add Watermark",
            p => p[nameof(WatermarkDialog.CurrentPage)] = Session.Pdf.CurrentPage
        );
        if (wm is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Applying watermark…");

            var applier = new StampApplier();
            if (wm.AllPages)
                await applier.StampAsync(Session.Pdf.Document, wm.Stamp);
            else
                await applier.StampPageAsync(Session.Pdf.Document, Session.Pdf.CurrentPage, wm.Stamp);

            await Session.Pdf.RefreshAsync();
            Feedback.Info(wm.AllPages ? "Watermark applied to all pages." : "Watermark applied to current page.");
        }
        catch (Exception ex)
        {
            Feedback.Error(ex.Message);
        }
    }

    private async Task CloseDocument()
    {
        await Session.ClosePdfAsync();
        _selectedProperties = null;
        _showTextPanel = false;
        _extractedText = null;
    }

    private static Task OpenNewFile() =>
        // Trigger the hidden InputFile
        Task.CompletedTask;

    private async Task OnOpenFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > StudioConstants.MaxUploadBytes)
        {
            Feedback.Error("File too large.");
            return;
        }

        using var ms = new MemoryStream();
        await using var stream = file.OpenReadStream(StudioConstants.MaxUploadBytes);
        await stream.CopyToAsync(ms);
        await LoadPdf((ms.ToArray(), file.Name));
    }

    private Task OnPlayboardDirty()
    {
        Session.Pdf?.MarkDirty();
        return Task.CompletedTask;
    }

}
