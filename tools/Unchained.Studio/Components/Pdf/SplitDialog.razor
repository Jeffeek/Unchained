<MudDialog Style="min-width:460px; max-width:560px;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Outlined.CallSplit" Class="mr-2" Style="vertical-align:middle;"/>
            Split Document
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2" Style="opacity:.7;">
                Splits the @PageCount-page document into one PDF per range, downloaded together
                as a ZIP. Each range is an inclusive page span.
            </MudText>

            <MudTextField @bind-Value="_rangesText"
                          Label="Ranges (one per output file)"
                          HelperText="Examples: 1-3, 4-6, 7-10  →  three PDFs. A single number like 5 = one-page PDF."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          Error="@(_error is not null)"
                          ErrorText="@_error"/>

            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SplitEachPage"
                       StartIcon="@Icons.Material.Outlined.AutoAwesomeMotion">
                One file per page
            </MudButton>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Confirm" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@string.IsNullOrWhiteSpace(_rangesText)"
                   StartIcon="@Icons.Material.Outlined.CallSplit">
            Split
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int PageCount { get; set; } = 1;

    private string _rangesText = string.Empty;
    private string? _error;

    private void SplitEachPage() =>
        _rangesText = string.Join(", ", Enumerable.Range(1, PageCount));

    private void Confirm()
    {
        // NOTE: intentionally NOT using the shared PageRangeParser. Split needs an ORDERED list
        // of ranges that may overlap (e.g. "1-3, 2-5" → two output files), whereas PageRangeParser
        // returns a deduplicated, sorted set of individual page numbers. The semantics differ.
        _error = null;
        var ranges = new List<(int Start, int End)>();

        foreach (var token in _rangesText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            int start, end;
            if (token.Contains('-'))
            {
                var parts = token.Split('-');
                if (parts.Length != 2 ||
                    !int.TryParse(parts[0].Trim(), out start) ||
                    !int.TryParse(parts[1].Trim(), out end))
                {
                    _error = $"Invalid range: \"{token}\"";
                    StateHasChanged();
                    return;
                }
            }
            else
            {
                if (!int.TryParse(token, out start))
                {
                    _error = $"Invalid page number: \"{token}\"";
                    StateHasChanged();
                    return;
                }

                end = start;
            }

            if (start < 1 || end > PageCount || start > end)
            {
                _error = $"Range {start}-{end} is out of bounds (1-{PageCount}).";
                StateHasChanged();
                return;
            }

            ranges.Add((start, end));
        }

        if (ranges.Count == 0)
        {
            _error = "Enter at least one range.";
            StateHasChanged();
            return;
        }

        MudDialog.Close(DialogResult.Ok(ranges));
    }

    private void Cancel() => MudDialog.Cancel();
}
