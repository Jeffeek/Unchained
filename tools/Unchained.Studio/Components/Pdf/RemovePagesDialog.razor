<MudDialog Style="min-width:420px; max-width:520px;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Outlined.Delete" Class="mr-2" Style="vertical-align:middle;"/>
            Remove Pages
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2" Style="opacity:.7;">
                Deletes the selected pages from the document (@PageCount page(s) total).
                At least one page must remain.
            </MudText>

            <MudTextField @bind-Value="_rangeText"
                          Label="Pages to remove"
                          HelperText="Examples: 1,3,5-8  or  2-5  or  1,4,7"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          Error="@(_error is not null)"
                          ErrorText="@_error"/>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Confirm" Color="Color.Error" Variant="Variant.Filled"
                   Disabled="@string.IsNullOrWhiteSpace(_rangeText)"
                   StartIcon="@Icons.Material.Outlined.Delete">
            Remove
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int PageCount { get; set; } = 1;

    private string _rangeText = string.Empty;
    private string? _error;

    private void Confirm()
    {
        var pages = PageRangeParser.Parse(_rangeText, PageCount, out _error);
        if (pages is null)
        {
            StateHasChanged();
            return;
        }

        if (pages.Count >= PageCount)
        {
            _error = "Cannot remove every page — at least one must remain.";
            StateHasChanged();
            return;
        }

        MudDialog.Close(DialogResult.Ok(pages));
    }

    private void Cancel() => MudDialog.Cancel();
}
