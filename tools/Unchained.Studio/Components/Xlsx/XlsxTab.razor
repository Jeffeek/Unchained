@page "/xlsx"
@using Unchained.Studio.Features.Xlsx
@using Unchained.Studio.Infrastructure
@using Unchained.Xlsx.Cell
@using Unchained.Xlsx.Drawings
@using Unchained.Xlsx.Models
@using Unchained.Xlsx.Models.Cell
@using Unchained.Xlsx.Models.Sheets
@using Unchained.Xlsx.Styles
@using Unchained.Xlsx.Worksheets
@using HorizontalAlignment = Unchained.Xlsx.Models.HorizontalAlignment
@inject SessionStateService Session
@inject XlsxEditorViewModel ViewModel
@inject FileExportService Exporter
@inject IUserFeedback Feedback
@implements IDisposable

<div class="studio-tab">
    @if (Session.Xlsx is null)
    {
        <div class="drop-zone-page">
            <FileDropZone Title="Drop a spreadsheet here"
                          Subtitle="Supports .xlsx and .csv"
                          Accept=".xlsx,.csv"
                          OnFileLoaded="LoadFile"
                          OnError="Feedback.Error"/>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Outlined.AddCircleOutline"
                       OnClick="CreateBlank"
                       Class="mt-3"
                       Style="align-self:center;">
                New Workbook
            </MudButton>
        </div>
    }
    else
    {
        var state = Session.Xlsx;
        var sheet = Sheet;

        <div class="three-panel">
            <!-- LEFT: tree -->
            <div class="panel-tree">
                <DocumentTree Root="state.Tree"
                              SelectedNodeChanged="OnNodeSelected"
                              OnRefreshRequested="RefreshTree"/>
            </div>

            <!-- CENTRE: grid + formula bar + info panel -->
            <div class="panel-preview">
                <div class="sheet-toolbar">
                    <MudTabs Rounded="true"
                             Elevation="0"
                             Class="sheet-tabbar"
                             @key="@state.CurrentSheet">
                        @foreach (var s in state.Document.Sheets)
                        {
                            <MudTabPanel Text="@(s.State == SheetState.Hidden ? $"{s.Name} (hidden)" : s.Name)"
                                         Class="@(s.State == SheetState.Hidden ? "sheet-tab--hidden" : string.Empty)"
                                         @onclick="() => SelectSheet(state.Document.Sheets.IndexOf(s) + 1)">
                                <MudTooltip Text="Rename" Class="sheet-tab-rename">
                                    <template>
                                        <span @onclick="() => RenameSheet(s)" @onclick:stopPropagation="true">@s.Name</span>
                                    </template>
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" Variant="Variant.Text"/>
                                </MudTooltip>
                                @if (state.Document.Sheets.Count > 1)
                                {
                                    <MudTooltip Text="Delete" Class="sheet-tab-delete">
                                        <template>
                                            <span class="sheet-tab-close" @onclick="() => DeleteSheet(s)" @onclick:stopPropagation="true">×</span>
                                        </template>
                                        <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small" Variant="Variant.Text"/>
                                    </MudTooltip>
                                }
                            </MudTabPanel>
                        }
                    </MudTabs>

                    <MudTooltip Text="Add sheet">
                        <MudIconButton Icon="@Icons.Material.Outlined.Add" Size="Size.Small" OnClick="AddSheet"/>
                    </MudTooltip>
                </div>

                @* ReSharper disable once ConditionIsAlwaysTrueOrFalseAccordingToNullableAPIContract *@
                @if (sheet is not null)
                {
                    <div class="format-toolbar">
                        <MudButtonGroup>
                            <MudIconButton Icon="@Icons.Material.Outlined.FormatBold" OnClick="() => QuickFont(static f => f.Bold = !f.Bold)"/>
                            <MudIconButton Icon="@Icons.Material.Outlined.FormatItalic" OnClick="() => QuickFont(static f => f.Italic = !f.Italic)"/>
                            <MudIconButton Icon="@Icons.Material.Outlined.FormatUnderlined" OnClick="() => QuickFont(static f => f.Underline = f.Underline != FontUnderline.Single ? FontUnderline.None : FontUnderline.Single)"/>
                        </MudButtonGroup>
                        <MudButtonGroup>
                            <MudIconButton Icon="@Icons.Material.Outlined.FormatAlignLeft" OnClick="() => QuickAlign(static a => a.Horizontal = HorizontalAlignment.Left)"/>
                            <MudIconButton Icon="@Icons.Material.Outlined.FormatAlignCenter" OnClick="() => QuickAlign(static a => a.Horizontal = HorizontalAlignment.Center)"/>
                            <MudIconButton Icon="@Icons.Material.Outlined.FormatAlignRight" OnClick="() => QuickAlign(static a => a.Horizontal = HorizontalAlignment.Right)"/>
                        </MudButtonGroup>
                        <MudButtonGroup>
                            <MudIconButton Icon="@Icons.Material.Outlined.WrapText" OnClick="() => QuickAlign(static a => a.WrapText = !a.WrapText)"/>
                            <MudIconButton Icon="@Icons.Material.Outlined.BorderAll" OnClick="QuickBorderAll"/>
                            @if (sheet.GetUsedRange() is { } ur && ur.Cells().Any())
                            {
                                <MudIconButton Icon="@Icons.Material.Outlined.MergeType" OnClick="MergeSelection" title="Merge selected cells"/>
                                <MudIconButton Icon="@Icons.Material.Outlined.CallSplit" OnClick="UnmergeSelection" title="Unmerge selected cells"/>
                            }
                        </MudButtonGroup>
                        <MudIconButton Icon="@Icons.Material.Outlined.FormatPaint" Size="Size.Small" OnClick="OpenFormatDialog"
                                       title="Format Cells"/>
                    </div>

                    <FormulaBar @ref="_formulaBar" Sheet="sheet"
                                Reference="@ViewModel.FormulaReference"
                                CellText="@ViewModel.FormulaText"
                                IsActive="@ViewModel.FormulaActive"
                                Committed="OnFormulaCommitted"
                                CellReferenceRequested="OnCellReferenceInserted"/>

                    @if (ViewModel.ShowTextPanel)
                    {
                        <div class="text-panel">
                            <div class="text-panel-toolbar">
                                <MudText Typo="Typo.subtitle2">Extracted Text</MudText>
                                <MudSpacer/>
                                <MudIconButton Icon="@Icons.Material.Outlined.Download" Size="Size.Small" OnClick="@DownloadText"/>
                                <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small" OnClick="() => ViewModel.ShowTextPanel = false"/>
                            </div>
                            <textarea class="text-content" readonly>@ViewModel.ExtractedText</textarea>
                        </div>
                    }

                    <SheetGrid @key="@($"{state.CurrentSheet}-{_gridVersion}")"
                               @ref="@_grid"
                               Sheet="sheet"
                               CellSelected="OnCellSelected"
                               SelectionChanged="OnSelectionChanged"
                               ChartSelected="OpenChartEditor"
                               OnGenerateRequested="OpenGenerateData"
                               OnEdited="OnGridEdited"
                               FormulaActiveChanged="OnFormulaActiveChanged"
                               FormulaBarRef="_formulaBar"/>
                }
            </div>

            <!-- RIGHT: properties -->
            <div class="panel-properties">
                <PropertiesPanel Bag="_selectedProperties"/>
            </div>
        </div>

        <!-- BOTTOM: operations bar -->
        <div class="operations-bar">
            <div class="ops-group">
                <MudMenu Label="Sheet" StartIcon="@Icons.Material.Outlined.GridOn" Variant="Variant.Text" Size="Size.Small" Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Outlined.ArrowUpward" OnClick="() => MoveSheet(-1)">Move left</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.ArrowDownward" OnClick="() => MoveSheet(1)">Move right</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.VisibilityOff" OnClick="ToggleHidden">@(sheet?.State == SheetState.Visible ? "Hide" : "Show")</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.DriveFileRenameOutline" OnClick=" () => RenameSheet(sheet!)">Rename…</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.GridView" OnClick="OpenSheetSettings">View &amp; layout…</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Print" OnClick="OpenPageSetup">Page setup…</MudMenuItem>
                </MudMenu>
                <MudMenu Label="Edit" StartIcon="@Icons.Material.Outlined.Edit" Variant="Variant.Text" Size="Size.Small" Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Outlined.Article" OnClick="OpenRowColumnDialog">Rows &amp; columns…</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.ContentPaste" OnClick="OpenPasteImport">Paste import…</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.FormatPaint" OnClick="OpenFormatDialog">Format cells…</MudMenuItem>
                </MudMenu>
                <MudMenu Label="Insert" StartIcon="@Icons.Material.Outlined.Add" Variant="Variant.Text" Size="Size.Small" Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Outlined.TableChart" OnClick="OpenTablesDialog">Table…</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Tune" OnClick="OpenNamedRangesDialog">Named range…</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.CheckCircle" OnClick="OpenDataValidationDialog">Data validation…</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Image" OnClick="OpenInsertImage">Image…</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.BarChart" OnClick="OpenInsertChart">Chart…</MudMenuItem>
                </MudMenu>
            </div>
            <MudDivider Vertical="true" Class="ops-divider"/>
            <div class="ops-group">
                <MudMenu Label="Data" StartIcon="@Icons.Material.Outlined.SettingsInputAntenna" Variant="Variant.Text" Size="Size.Small" Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Outlined.AutoAwesome" OnClick="OpenGenerateData">Generate data…</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.UploadFile" OnClick="OpenCsvExport">Export CSV…</MudMenuItem>
                </MudMenu>
                <MudButton StartIcon="@Icons.Material.Outlined.Settings"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenProtectionDialog">
                    Protection
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Info"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenMetadataDialog">
                    Metadata
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.TextFields"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="ExtractText">
                    Extract text
                </MudButton>
            </div>
            <MudDivider Vertical="true" Class="ops-divider"/>
            <div class="ops-group ops-group--right">
                <MudButton StartIcon="@Icons.Material.Outlined.Download"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="OpenSaveDialog">
                    Download
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Close"
                           Variant="Variant.Text"
                           Color="Color.Error"
                           Size="Size.Small"
                           OnClick="CloseDocument">
                    Close
                </MudButton>
            </div>
        </div>
    }
</div>

@code {
    private PropertyBag? _selectedProperties;
    private int _gridVersion;
    private FormulaBar? _formulaBar;
    @* ReSharper disable once NotAccessedField.Local *@
    private SheetGrid? _grid;

    protected override void OnInitialized() => ViewModel.Changed += OnViewModelChanged;

    public void Dispose()
    {
        ViewModel.Changed -= OnViewModelChanged;
        DetachSession();
    }

    private void OnViewModelChanged() => InvokeAsync(StateHasChanged);

    private Worksheet? Sheet => Session.Xlsx?.Document.Sheets[Session.Xlsx.CurrentSheet - 1];

    private void AttachSession()
    {
        if (Session.Xlsx is not null)
            Session.Xlsx.Refreshed += OnSessionRefreshed;
    }

    private void DetachSession()
    {
        if (Session.Xlsx is not null)
            Session.Xlsx.Refreshed -= OnSessionRefreshed;
    }

    private void OnSessionRefreshed() => InvokeAsync(StateHasChanged);

    // ── File / load / create ────────────────────────────────────────────────

    private async Task LoadFile((byte[] Bytes, string FileName) file)
    {
        if (file.Bytes.Length > StudioConstants.MaxUploadBytes)
        {
            Feedback.Error("File too large.");
            return;
        }

        var isCsv = file.FileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase);

        try
        {
            DetachSession();
            if (isCsv)
                await Session.LoadCsvAsync(file.Bytes, file.FileName);
            else
                await Session.LoadXlsxAsync(file.Bytes, file.FileName);
            AttachSession();
            Feedback.Info($"Loaded {file.FileName}");
        }
        catch (Exception ex)
        {
            Feedback.Error($"Failed to load {(isCsv ? "CSV" : "workbook")}: {ex.Message}");
        }
    }

    private async Task CreateBlank()
    {
        try
        {
            DetachSession();
            await Session.CreateBlankXlsxAsync();
            AttachSession();
            Feedback.Info("Created a blank workbook");
        }
        catch (Exception ex)
        {
            Feedback.Error($"Failed to create workbook: {ex.Message}");
        }
    }

    private void OnNodeSelected(TreeNode? node)
    {
        _selectedProperties = node is null ? null : XlsxPropertyAdapter.Build(node);

        if (node is not { NodeType: TreeNodeType.Sheet, Payload: Worksheet ws } || Session.Xlsx is null) return;

        var idx = Session.Xlsx.Document.Sheets.IndexOf(ws);
        if (idx >= 0)
            SelectSheet(idx + 1);
    }

    // ── Thin wrappers for VM callbacks ──────────────────────────────────────

    private void OnCellSelected(Cell? cell)
    {
        _selectedProperties = cell is null ? null : XlsxPropertyAdapter.ForCell(cell);
        ViewModel.OnCellSelected(cell);
    }

    private void OnSelectionChanged(CellRange range) => ViewModel.OnSelectionChanged(range);

    private Task OnCellReferenceInserted((CellReference Reference, int CursorPos) tuple)
    {
        ViewModel.OnCellReferenceInserted(tuple);
        return Task.CompletedTask;
    }

    private void OnFormulaActiveChanged(bool active) => ViewModel.OnFormulaActiveChanged(active);
    private void OnGridEdited() => ViewModel.OnGridEdited();
    private void OnFormulaCommitted(string text) => ViewModel.OnFormulaCommitted(text);

    private async Task RefreshTree()
    {
        if (Session.Xlsx is null) return;

        try
        {
            await Session.Xlsx.RefreshAsync();
            _gridVersion++;
        }
        catch (Exception ex)
        {
            Feedback.Error($"Refresh failed: {ex.Message}");
        }
    }

    // ── Quick formatting ────────────────────────────────────────────────────

    private void QuickFont(Action<CellFont> mutate) => ViewModel.QuickFont(mutate);
    private void QuickAlign(Action<CellAlignment> mutate) => ViewModel.QuickAlign(mutate);
    private void QuickBorderAll() => ViewModel.QuickBorderAll();
    private void MergeSelection() => ViewModel.MergeSelection();
    private void UnmergeSelection() => ViewModel.UnmergeSelection();

    private void OpenFormatDialog() => _ = ViewModel.OpenFormatDialog();

    // ── Sheet management ────────────────────────────────────────────────────

    private void SelectSheet(int number) => ViewModel.SelectSheet(number);
    private void AddSheet() => ViewModel.AddSheet();
    private Task DeleteSheet(Worksheet sheet) => ViewModel.DeleteSheet(sheet);
    private Task RenameSheet(Worksheet sheet) => ViewModel.RenameSheet(sheet);
    private void MoveSheet(int delta) => ViewModel.MoveSheet(delta);
    private void ToggleHidden() => ViewModel.ToggleHidden();

    // ── Dialog launchers ────────────────────────────────────────────────────

    private Task OpenRowColumnDialog() => ViewModel.OpenRowColumnDialog();
    private Task OpenTablesDialog() => ViewModel.OpenTablesDialog();
    private Task OpenNamedRangesDialog() => ViewModel.OpenNamedRangesDialog();
    private Task OpenDataValidationDialog() => ViewModel.OpenDataValidationDialog();
    private Task OpenInsertImage() => ViewModel.OpenInsertImage();
    private Task OpenInsertChart() => ViewModel.OpenInsertChart();
    private Task OpenGenerateData() => ViewModel.OpenGenerateData();
    private Task OpenChartEditor(ChartDrawing chart) => ViewModel.OpenChartEditor(chart);
    private Task OpenSheetSettings() => ViewModel.OpenSheetSettings();
    private Task OpenPageSetup() => ViewModel.OpenPageSetup();
    private Task OpenProtectionDialog() => ViewModel.OpenProtectionDialog();
    private Task OpenPasteImport() => ViewModel.OpenPasteImport();
    private Task OpenMetadataDialog() => ViewModel.OpenMetadataDialog();
    private Task OpenCsvExport() => ViewModel.OpenCsvExport();
    private Task OpenSaveDialog() => ViewModel.OpenSaveDialog();

    // ── Document operations ─────────────────────────────────────────────────

    private void ExtractText() => ViewModel.ExtractText();
    private void DownloadText() => ViewModel.DownloadText(Exporter);

    private async Task CloseDocument()
    {
        DetachSession();
        await Session.CloseXlsxAsync();
        _selectedProperties = null;
        ViewModel.ShowTextPanel = false;
    }

}
