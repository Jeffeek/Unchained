    // ── Extract text ────────────────────────────────────────────────────────

    private void ExtractText()
    {
        if (Sheet is null)
            return;

        _extractedText = Sheet.GetAllText();
        _showTextPanel = true;
    }

    private Task DownloadText() =>
        _extractedText is null ? Task.CompletedTask : Exporter.TriggerDownloadAsync(
            Encoding.UTF8.GetBytes(_extractedText),
            Path.ChangeExtension(Session.Xlsx?.FileName ?? "workbook", ".txt"),
            "text/plain"
        );

    private async Task CloseDocument()
    {
        DetachSession();
        await Session.CloseXlsxAsync();
        _selectedProperties = null;
        _showTextPanel = false;
        _extractedText = null;
    }

    // ── Helpers ────────────────────────────────────────────────────────────────

    private EventCallback AfterMutation() => EventCallback.Factory.Create(
        this,
        () =>
        {
            Session.Xlsx?.MarkDirty();
        }
    );

    private EventCallback AfterMutationAndGrid() => EventCallback.Factory.Create(
        this,
        () =>
        {
            Session.Xlsx?.MarkDirty();
            _gridVersion++;
        }
    );

    private static DialogOptions Small() =>
        new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

    private static DialogOptions Wide() =>
        new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

    private void AttachSession()
    {
        if (Session.Xlsx is not null)
            Session.Xlsx.Refreshed += OnSessionRefreshed;
    }

    private void DetachSession()
    {
        if (Session.Xlsx is not null)
            Session.Xlsx.Refreshed -= OnSessionRefreshed;
    }

    private void SetBusy(string message)
    {
        _busy = true;
        _busyMessage = message;
        StateHasChanged();
    }

    private void ClearBusy()
    {
        _busy = false;
        StateHasChanged();
    }

    private void ShowInfo(string message) => Snackbar.Add(message, Severity.Info);
    private void ShowError(string message) => Snackbar.Add(message, Severity.Error);
}
