@using Unchained.Xlsx.Cell
@using Unchained.Xlsx.Drawings
@using Unchained.Xlsx.Models.Cell
@using Unchained.Xlsx.Worksheets
<div class="sheet-grid-wrapper">
    <div class="sheet-grid-toolbar">
        <MudText Typo="Typo.subtitle2" Class="mr-2">@Sheet.Name</MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@SelectionLabel</MudChip>
        <MudSpacer/>
        <MudTooltip Text="Generate data…">
            <MudIconButton Icon="@Icons.Material.Outlined.AutoAwesome" Size="Size.Small" OnClick="OnGenerateRequested"/>
        </MudTooltip>
        <MudTooltip Text="Add display row">
            <MudIconButton Icon="@Icons.Material.Outlined.Add" Size="Size.Small" OnClick="AddRow"/>
        </MudTooltip>
        <MudTooltip Text="Add display column">
            <MudIconButton Icon="@Icons.Material.Outlined.AddBox" Size="Size.Small" OnClick="AddColumn"/>
        </MudTooltip>
        <MudTooltip Text="Clear selection">
            <MudIconButton Icon="@Icons.Material.Outlined.Backspace" Size="Size.Small" OnClick="ClearSelection"/>
        </MudTooltip>
    </div>

    <div class="sheet-grid-scroll" @onmouseup="EndDrag" @onmouseleave="EndDrag" @onmousemove="OnGridMouseMove"
         @oncontextmenu:preventDefault="true" @oncontextmenu="OnGridContextMenu"
         @onclick="OnScrollAreaClick">
        <table class="sheet-grid">
            <thead>
            <tr>
                <th class="sg-corner" @onclick="SelectAll"></th>
                @for (var c = 1; c <= _cols; c++)
                {
                    var col = c;
                    <th class="sg-col-head" style="@SheetGridDisplay.ColumnHeadStyle(Sheet, col)" @onclick="() => SelectColumn(col)">
                        <span>@CellReference.ColumnNumberToLetters(col)</span>
                        <span class="sg-col-resize" @onmousedown:stopPropagation="true"
                              @onmousedown="e => StartColResize(col, e)">
                        </span>
                    </th>
                }
            </tr>
            </thead>
            <tbody>
            @for (var r = 1; r <= _rows; r++)
            {
                var row = r;
                <tr style="@SheetGridDisplay.RowStyle(Sheet, row)">
                    <th class="sg-row-head" @onclick="() => SelectRow(row)">
                        <span>@row</span>
                        <span class="sg-row-resize" @onmousedown:stopPropagation="true"
                              @onmousedown="e => StartRowResize(row, e)">
                        </span>
                    </th>
                    @for (var c = 1; c <= _cols; c++)
                    {
                        var col = c;
                        var isEditing = _editRow == row && _editCol == col;
                        <td class="@SheetGridDisplay.CellClass(Sheet, row, col, InSelection(row, col), row == _activeRow && col == _activeCol)" style="@SheetGridDisplay.CellStyle(Sheet, row, col)"
                            @onmousedown="e => OnCellMouseDown(row, col, e)"
                            @onmouseover="() => OnCellMouseOver(row, col)"
                            @ondblclick="() => BeginEdit(row, col)">
                            @if (isEditing)
                            {
                                <input class="sg-input"
                                       value="@_editValue"
                                       @ref="_editInput"
                                       @oninput="CommitEditEvent"
                                       @onblur="CommitEdit"
                                       @onkeydown="OnEditKeyDown"/>
                            }
                            else
                            {
                                @SheetGridDisplay.DisplayValue(Sheet, row, col)
                            }
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>

        @* Drawing overlay: images and charts float above the cell grid. *@
        @foreach (var drawing in Sheet.Drawings)
        {
            var box = SheetGridDisplay.DrawingBox(Sheet, drawing);
            switch (drawing)
            {
                case PictureDrawing pic:
                    var isPicSelected = _selectedDrawing == pic;
                    <div class="@(isPicSelected ? "sg-drawing sg-drawing--selected" : "sg-drawing")" style="@box"
                         @onmousedown="e => OnDrawingMouseDown(pic, e)"
                         @onmousedown:stopPropagation="true"
                         @onclick:stopPropagation="true"
                         @oncontextmenu:preventDefault="true" @oncontextmenu="e => OnDrawingContextMenu(pic, e)"
                         @oncontextmenu:stopPropagation="true">
                        <img class="sg-drawing-img" src="@SheetGridDisplay.ImageDataUri(pic)" alt="@pic.Name"/>
                        @if (isPicSelected)
                        {
                            <div class="sg-drawing-handle sg-drawing-handle--tl" @onmousedown="e => StartResizeDrawing(pic, e, DrawingResizeDir.TopLeft)"
                                 @onmousedown:stopPropagation="true">
                            </div>
                            <div class="sg-drawing-handle sg-drawing-handle--tr" @onmousedown="e => StartResizeDrawing(pic, e, DrawingResizeDir.TopRight)"
                                 @onmousedown:stopPropagation="true">
                            </div>
                            <div class="sg-drawing-handle sg-drawing-handle--bl" @onmousedown="e => StartResizeDrawing(pic, e, DrawingResizeDir.BottomLeft)"
                                 @onmousedown:stopPropagation="true">
                            </div>
                            <div class="sg-drawing-handle sg-drawing-handle--br" @onmousedown="e => StartResizeDrawing(pic, e, DrawingResizeDir.BottomRight)"
                                 @onmousedown:stopPropagation="true">
                            </div>
                            <div class="sg-drawing-edit">
                                <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" OnClick="() => DeleteDrawing(pic)"/>
                            </div>
                        }
                    </div>
                break;
                case ChartDrawing chart:
                    var isSelected = _selectedDrawing == chart;
                    <div class="@SheetGridDisplay.DrawingClass(chart, isSelected)" style="@SheetGridDisplay.DrawingBox(Sheet, chart)"
                         @onmousedown="e => OnDrawingMouseDown(chart, e)"
                         @onmousedown:stopPropagation="true"
                         @onclick:stopPropagation="true"
                         @ondblclick="() => OnChartDoubleClick(chart)"
                         @oncontextmenu:preventDefault="true" @oncontextmenu="e => OnChartContextMenu(chart, e)"
                         @oncontextmenu:stopPropagation="true">
                        <ChartView Model="chart.Chart" ChartSize="SheetGridDisplay.DrawingSize(Sheet, chart)"/>
                        @if (isSelected)
                        {
                            <div class="sg-drawing-handle sg-drawing-handle--tl" @onmousedown="e => StartResizeDrawing(chart, e, DrawingResizeDir.TopLeft)"
                                 @onmousedown:stopPropagation="true">
                            </div>
                            <div class="sg-drawing-handle sg-drawing-handle--tr" @onmousedown="e => StartResizeDrawing(chart, e, DrawingResizeDir.TopRight)"
                                 @onmousedown:stopPropagation="true">
                            </div>
                            <div class="sg-drawing-handle sg-drawing-handle--bl" @onmousedown="e => StartResizeDrawing(chart, e, DrawingResizeDir.BottomLeft)"
                                 @onmousedown:stopPropagation="true">
                            </div>
                            <div class="sg-drawing-handle sg-drawing-handle--br" @onmousedown="e => StartResizeDrawing(chart, e, DrawingResizeDir.BottomRight)"
                                 @onmousedown:stopPropagation="true">
                            </div>
                        }
                        <div class="sg-drawing-edit">
                            <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" OnClick="() => DeleteDrawing(chart)"/>
                        </div>
                    </div>
                break;
            }
        }
    </div>

    @* Context menu *@
    @if (_contextMenuVisible)
    {
        <div class="sg-context-menu" style="left:@_contextMenuX px;top:@_contextMenuY px;">
            @if (HasChartMenu)
            {
                <div class="sg-context-menu-item" @onclick="() => { CloseContextMenu(); ChartSelected.InvokeAsync((ChartDrawing)_contextMenuTarget!); }">
                    <MudIcon Icon="@Icons.Material.Outlined.Edit" Size="Size.Small"/><span>Edit chart…</span>
                </div>
                <div class="sg-context-menu-item" @onclick="CloseContextMenu">
                    <MudIcon Icon="@Icons.Material.Outlined.Insights" Size="Size.Small"/><span>Visualize</span>
                </div>
                <div class="sg-context-menu-separator"></div>
                <div class="sg-context-menu-item" @onclick="() => { CloseContextMenu(); DeleteDrawing((WorksheetDrawing)_contextMenuTarget!); }">
                    <MudIcon Icon="@Icons.Material.Outlined.Delete" Size="Size.Small"/><span>Delete chart</span>
                </div>
            }
            else if (HasImageMenu)
            {
                <div class="sg-context-menu-item" @onclick="() => { CloseContextMenu(); DeleteDrawing((WorksheetDrawing)_contextMenuTarget!); }">
                    <MudIcon Icon="@Icons.Material.Outlined.Delete" Size="Size.Small"/><span>Delete image</span>
                </div>
            }
            else
            {
                <div class="sg-context-menu-item" @onclick="CloseContextMenu">
                    <MudIcon Icon="@Icons.Material.Outlined.KeyboardArrowUp" Size="Size.Small"/><span>Insert row</span>
                </div>
                <div class="sg-context-menu-item" @onclick="CloseContextMenu">
                    <MudIcon Icon="@Icons.Material.Outlined.KeyboardArrowLeft" Size="Size.Small"/><span>Insert column</span>
                </div>
                <div class="sg-context-menu-separator"></div>
                <div class="sg-context-menu-item" @onclick="CloseContextMenu">
                    <MudIcon Icon="@Icons.Material.Outlined.DeleteForever" Size="Size.Small"/><span>Delete row</span>
                </div>
                <div class="sg-context-menu-item" @onclick="CloseContextMenu">
                    <MudIcon Icon="@Icons.Material.Outlined.DeleteForever" Size="Size.Small"/><span>Delete column</span>
                </div>
            }
        </div>
    }
</div>

@code {

    [Parameter]
    public Worksheet Sheet { get; set; } = null!;

    /// <summary>Raised when the active (anchor) cell changes; <see langword="null" /> when empty.</summary>
    [Parameter]
    public EventCallback<Cell?> CellSelected { get; set; }

    /// <summary>Raised when the selected range changes (single cell = 1×1 range).</summary>
    [Parameter]
    public EventCallback<CellRange> SelectionChanged { get; set; }

    /// <summary>Raised whenever an edit mutates the document so the host can flag it dirty.</summary>
    [Parameter]
    public EventCallback OnEdited { get; set; }

    /// <summary>Raised when a chart drawing is clicked, so the host can open the chart editor.</summary>
    [Parameter]
    public EventCallback<ChartDrawing> ChartSelected { get; set; }

    /// <summary>Raised when the user clicks the generate button, requesting the generate-data dialog.</summary>
    [Parameter]
    public EventCallback OnGenerateRequested { get; set; }

    /// <summary>Callback when the formula bar active state changes (user starts/stops editing).</summary>
    [Parameter]
    public EventCallback<bool> FormulaActiveChanged { get; set; }

    /// <summary>The formula bar reference, for inserting cell references into the formula.</summary>
    [Parameter]
    public FormulaBar? FormulaBarRef { get; set; }

    private const int MinRows = 30;
    private const int MinCols = 12;
    private const int PadRows = 8;
    private const int PadCols = 4;

    private int _rows = MinRows;
    private int _cols = MinCols;

    protected override void OnParametersSet() => RecalculateDimensions();

    private void RecalculateDimensions()
    {
        var used = Sheet.GetUsedRange();
        var usedRows = used?.BottomRight.Row ?? 0;
        var usedCols = used?.BottomRight.Column ?? 0;
        _rows = Math.Max(_rows, Math.Max(MinRows, usedRows + PadRows));
        _cols = Math.Max(_cols, Math.Max(MinCols, usedCols + PadCols));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_focusPending)
            return;

        _focusPending = false;
        try { await _editInput.FocusAsync(); }
        catch
        {
            /* element may have been replaced — ignore */
        }
    }

    // ── Drag end (resize / chart drag / cell drag) ─────────────────────────────

    private async Task EndDrag()
    {
        if (_resizeCol != -1 || _resizeRow != -1)
        {
            await FinishResize();
            return;
        }

        if (_dragChart != null)
        {
            _dragChart = null;
            await OnEdited.InvokeAsync();
            return;
        }

        if (_resizeChart != null)
        {
            _resizeChart = null;
            await OnEdited.InvokeAsync();
            return;
        }

        _dragging = false;
    }

    // ── Display dimensions ─────────────────────────────────────────────────────

    private void AddRow() => _rows++;
    private void AddColumn() => _cols++;

    /// <summary>Re-reads cell content + forces a redraw (called by the host after external mutations).</summary>
    public void Invalidate()
    {
        RecalculateDimensions();
        StateHasChanged();
    }

}
