@using Unchained.Ooxml.Charts
@using Unchained.Ooxml.Drawing
@using MudChartType = MudBlazor.ChartType
@using MudBlazorChartSeries = MudBlazor.ChartSeries<double>
@using OoxmlChartType = Unchained.Ooxml.Charts.ChartType

@if (_supported)
{
    <div class="sg-chart-view">
        @if (Model.HasTitle && !string.IsNullOrEmpty(Model.Title))
        {
            <div class="sg-chart-title">@Model.Title</div>
        }
        @if (_kind is MudChartType.Pie or MudChartType.Donut)
        {
            <MudChart T="double" ChartType="_kind"
                      inputData="@_pieData"
                      inputLabels="@_pieLabels"
                      chartOptions="Options"
                      Width="100%" Height="100%"/>
        }
        else
        {
            <MudChart T="double" ChartType="_kind"
                      chartSeries="Series"
                      xAxisLabels="_categories"
                      chartOptions="Options"
                      Width="100%" Height="100%"/>
        }
    </div>
}
else
{
    <div class="sg-drawing-chart">
        <MudIcon Icon="@Icons.Material.Outlined.BarChart" Size="Size.Small"/>
        <span>@FallbackLabel</span>
    </div>
}

@code {

    /// <summary>The chart model to visualise.</summary>
    [Parameter]
    public ChartModel Model { get; set; } = null!;

    private bool _supported;
    private MudChartType _kind;
    public List<MudBlazorChartSeries> Series { get; private set; } = [];
    private string[] _categories = [];
    private double[] _pieData = [];
    private string[] _pieLabels = [];
    private MudBlazor.ChartOptions Options = new();

    // Default series palette (hex without '#') used when a series has no explicit fill.
    private static readonly string[] DefaultPalette =
    [
        "4472C4", "ED7D31", "A5A5A5", "FFC000", "5B9BD5", "70AD47",
        "264478", "9E480E", "636363", "997300", "255E91", "43682B"
    ];

    protected override void OnParametersSet() => Rebuild();

    private void Rebuild()
    {
        _supported = IsSupported(Model.Type);
        if (!_supported)
            return;

        _kind = MapKind(Model.Type);
        _categories = Model.Data.Categories.ToArray();
        Options = new MudBlazor.ChartOptions
        {
            ChartPalette = BuildPalette()
        };

        if (_kind is MudChartType.Pie or MudChartType.Donut)
        {
            var first = Model.Data.Series.Count > 0 ? Model.Data.Series[0] : null;
            _pieData = first?.Values.ToArray() ?? [];
            _pieLabels = _categories.Length > 0 ? _categories : Enumerable.Range(1, _pieData.Length).Select(static n => n.ToString()).ToArray();
            return;
        }

        Series = Model.Data.Series
            .Select(static s => new MudBlazorChartSeries { Name = s.Name, Data = s.Values.ToArray() })
            .ToList();
    }

    private string[] BuildPalette()
    {
        var palette = new string[Math.Max(Model.Data.Series.Count, 1)];
        for (var i = 0; i < palette.Length; i++)
        {
            var explicitHex = i < Model.Data.Series.Count ? SeriesHex(Model.Data.Series[i]) : null;
            palette[i] = "#" + (explicitHex ?? DefaultPalette[i % DefaultPalette.Length]);
        }

        // Pie/donut slices are coloured per category, not per series.
        return _kind is not (MudChartType.Pie or MudChartType.Donut) || _categories.Length <= 1 ? palette : Enumerable.Range(0, _categories.Length)
            .Select(static i => "#" + DefaultPalette[i % DefaultPalette.Length])
            .ToArray();
    }

    private static string? SeriesHex(ChartSeries series) =>
        series.Fill is { Type: FillType.Solid, Solid.Color: var color } ? XlsxColor.ToHex(color).TrimStart('#') : null;

    private string FallbackLabel =>
        string.IsNullOrEmpty(Model.Title) ? $"{Model.Type} chart (preview unavailable)" : Model.Title;

    private static MudChartType MapKind(OoxmlChartType type) => type switch
    {
        OoxmlChartType.Pie or OoxmlChartType.PieExploded => MudChartType.Pie,
        OoxmlChartType.Doughnut or OoxmlChartType.DoughnutExploded => MudChartType.Donut,
        OoxmlChartType.Line or OoxmlChartType.LineStacked or OoxmlChartType.LineFullStacked
            or OoxmlChartType.LineWithMarkers or OoxmlChartType.LineWithMarkersStacked
            or OoxmlChartType.LineWithMarkersFullStacked
            or OoxmlChartType.Area or OoxmlChartType.AreaStacked or OoxmlChartType.AreaFullStacked => MudChartType.Line,
        OoxmlChartType.ColumnStacked or OoxmlChartType.ColumnFullStacked
            or OoxmlChartType.BarStacked or OoxmlChartType.BarFullStacked => MudChartType.StackedBar,
        _ => MudChartType.Bar
    };

    private static bool IsSupported(OoxmlChartType type) => type switch
    {
        OoxmlChartType.ScatterWithMarkersOnly or OoxmlChartType.ScatterWithStraightLines
            or OoxmlChartType.ScatterWithSmoothLines or OoxmlChartType.ScatterWithStraightLinesAndMarkers
            or OoxmlChartType.ScatterWithSmoothLinesAndMarkers or OoxmlChartType.Bubble
            or OoxmlChartType.Radar or OoxmlChartType.RadarWithMarkers or OoxmlChartType.RadarFilled => false,
        _ => true
    };

}
