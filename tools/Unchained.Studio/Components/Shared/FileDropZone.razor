@inject IJSRuntime JS

<div class="drop-zone @(_isDragging ? "drop-zone--dragging" : "")"
     @ondragenter="OnDragEnter"
     @ondragleave="OnDragLeave"
     @ondragover:preventDefault="true"
     @ondrop="OnDrop"
     @ondrop:preventDefault="true">

    <MudIcon Icon="@Icon" Style="font-size:3rem; opacity:0.5;" Class="mb-2" />
    <MudText Typo="Typo.h6" Class="mb-1">@Title</MudText>
    <MudText Typo="Typo.body2" Style="opacity:0.6" Class="mb-3">@Subtitle</MudText>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.FolderOpen"
               OnClick="OpenFilePicker">
        Browse&hellip;
    </MudButton>

    <InputFile id="@_inputId"
               OnChange="OnFileSelected"
               accept="@Accept"
               style="display:none;" />
</div>

@code {
    [Parameter] public string Title { get; set; } = "Drop a file here";
    [Parameter] public string Subtitle { get; set; } = "or click Browse";
    [Parameter] public string Icon { get; set; } = Icons.Material.Outlined.UploadFile;
    [Parameter] public string Accept { get; set; } = ".pdf";
    [Parameter] public long MaxSizeBytes { get; set; } = 100 * 1024 * 1024;
    [Parameter] public EventCallback<(byte[] Bytes, string FileName)> OnFileLoaded { get; set; }
    [Parameter] public EventCallback<string> OnError { get; set; }

    private readonly string _inputId = $"file-input-{Guid.NewGuid():N}";
    private bool _isDragging;
    private bool _loading;

    private void OnDragEnter() => _isDragging = true;
    private void OnDragLeave() => _isDragging = false;

    private async Task OnDrop(DragEventArgs e)
    {
        _isDragging = false;
        // JS interop needed for DataTransfer files — trigger the file input instead
        await JS.InvokeVoidAsync("unchainedStudio.clickElement", _inputId);
    }

    private async Task OpenFilePicker() =>
        await JS.InvokeVoidAsync("unchainedStudio.clickElement", _inputId);

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        if (_loading)
            return;

        _loading = true;
        try
        {
            var file = e.File;
            if (file.Size > MaxSizeBytes)
            {
                await OnError.InvokeAsync($"File is too large ({file.Size / 1024 / 1024} MB). Maximum is {MaxSizeBytes / 1024 / 1024} MB.");
                return;
            }

            using var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(MaxSizeBytes);
            await stream.CopyToAsync(ms);
            await OnFileLoaded.InvokeAsync((ms.ToArray(), file.Name));
        }
        catch (Exception ex)
        {
            await OnError.InvokeAsync($"Failed to read file: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
