@using Unchained.Ooxml
@using Unchained.Ooxml.Drawing
@using Unchained.Ooxml.Text
@using Unchained.Pptx.Animations
@using Unchained.Pptx.Shapes

@if (Shape is not null)
{
    <MudTabs Elevation="0" Rounded="true" Class="shape-props">
        <MudTabPanel Text="Geometry">
            <MudStack Spacing="3" Class="pa-4">
                <MudTextField @bind-Value="_name" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                <MudTextField @bind-Value="_altText" Label="Alt text" Variant="Variant.Outlined" Margin="Margin.Dense"/>

                <MudText Typo="Typo.subtitle2">Position</MudText>
                <div class="d-flex gap-2">
                    <MudNumericField T="double" @bind-Value="_x" Label="X (in)" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                    <MudNumericField T="double" @bind-Value="_y" Label="Y (in)" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                </div>

                <MudText Typo="Typo.subtitle2">Size</MudText>
                <div class="d-flex gap-2">
                    <MudNumericField T="double" @bind-Value="_width" Label="W (in)" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                    <MudNumericField T="double" @bind-Value="_height" Label="H (in)" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                </div>

                <div class="d-flex gap-2">
                    <MudNumericField T="double" @bind-Value="_rotation" Label="Rotation (°)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="-360" Max="360"/>
                    <MudSwitch T="bool" @bind-Value="_flipH" Label="Flip H" Color="Color.Primary"/>
                    <MudSwitch T="bool" @bind-Value="_flipV" Label="Flip V" Color="Color.Primary"/>
                </div>

                <div class="d-flex gap-2">
                    <MudSwitch T="bool" @bind-Value="_hidden" Label="Hidden" Color="Color.Primary"/>
                    <MudSwitch T="bool" @bind-Value="_decorative" Label="Decorative" Color="Color.Primary"/>
                </div>
            </MudStack>
        </MudTabPanel>

        <MudTabPanel Text="Fill">
            <MudStack Spacing="3" Class="pa-4">
                <MudSelect T="FillType" @bind-Value="_fillType" Label="Fill type" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="FillType.None">None</MudSelectItem>
                    <MudSelectItem Value="FillType.Solid">Solid</MudSelectItem>
                    <MudSelectItem Value="FillType.Gradient">Gradient</MudSelectItem>
                    <MudSelectItem Value="FillType.Pattern">Pattern</MudSelectItem>
                </MudSelect>

                @if (_fillType == FillType.Solid)
                {
                    <MudColorPicker Label="Fill colour" @bind-Text="_fillHex"
                                    Variant="Variant.Outlined" Margin="Margin.Dense"
                                    Style="max-width:200px;"/>
                }

                @if (_fillType == FillType.Pattern)
                {
                    <div class="d-flex gap-2">
                        <MudColorPicker Label="Foreground" @bind-Text="_fgHex"
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        Style="max-width:150px;"/>
                        <MudColorPicker Label="Background" @bind-Text="_bgHex"
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        Style="max-width:150px;"/>
                    </div>
                }
            </MudStack>
        </MudTabPanel>

        <MudTabPanel Text="Line">
            <MudStack Spacing="3" Class="pa-4">
                <MudSelect T="LineStyle" @bind-Value="_lineStyle" Label="Line style" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="LineStyle.NoLine">No line</MudSelectItem>
                    <MudSelectItem Value="LineStyle.Single">Single</MudSelectItem>
                </MudSelect>

                @if (_lineStyle != LineStyle.NoLine)
                {
                    <MudColorPicker Label="Line colour" @bind-Text="_lineColor"
                                    Variant="Variant.Outlined" Margin="Margin.Dense"
                                    Style="max-width:200px;"/>
                    <MudNumericField T="double" @bind-Value="_lineWidth" Label="Width (pt)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="100"/>
                }
            </MudStack>
        </MudTabPanel>

        @if (Shape is AutoShape autoShape)
        {
            <MudTabPanel Text="Text">
                <MudStack Spacing="3" Class="pa-4">
                    @if (autoShape.TextFrame.Paragraphs.Count > 0)
                    {
                        @foreach (var para in autoShape.TextFrame.Paragraphs)
                        {
                            <MudTextField @bind-Value="para.PlainText" Label="Paragraph" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Style="opacity:.6;">No text paragraphs.</MudText>
                    }
                </MudStack>
            </MudTabPanel>
        }

        <MudTabPanel Text="Effects">
            <MudStack Spacing="3" Class="pa-4">
                <MudSwitch T="bool" @bind-Value="_originalShadow" Label="Drop shadow" Color="Color.Primary"/>
                <MudSwitch T="bool" @bind-Value="_originalGlow" Label="Glow" Color="Color.Primary"/>
                <MudSwitch T="bool" @bind-Value="_originalReflection" Label="Reflection" Color="Color.Primary"/>
            </MudStack>
        </MudTabPanel>

        <MudTabPanel Text="Hyperlink">
            <MudStack Spacing="3" Class="pa-4">
                <MudTextField @bind-Value="_hyperlinkUrl" Label="URL" Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudStack>
        </MudTabPanel>
    </MudTabs>

    <div class="shape-props-actions">
        <MudButton OnClick="Apply" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
            Apply
        </MudButton>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Size="Size.Small">
            Cancel
        </MudButton>
    </div>
}

@code {

    [Parameter]
    public Shape Shape { get; set; } = null!;

    [Parameter]
    public Action OnChanged { get; set; } = static () => { };

    [Parameter]
    public EventCallback OnDelete { get; set; }

    private string _name = string.Empty;
    private string _altText = string.Empty;
    private double _x;
    private double _y;
    private double _width;
    private double _height;
    private double _rotation;
    private bool _flipH;
    private bool _flipV;
    private bool _hidden;
    private bool _decorative;

    private FillType _fillType = FillType.None;
    private string _fillHex = "#000000";
    private string _fgHex = "#000000";
    private string _bgHex = "#ffffff";

    private LineStyle _lineStyle = LineStyle.NoLine;
    private string _lineColor = "#000000";
    private double _lineWidth = 1;

    private bool _shadow;
    private bool _glow;
    private bool _reflection;

    private bool _originalShadow;
    private bool _originalGlow;
    private bool _originalReflection;

    private string _hyperlinkUrl = string.Empty;

    private FillType _originalFillType = FillType.None;
    private ColorSpec? _originalFillColor;
    private ColorSpec? _originalFillFgColor;
    private ColorSpec? _originalFillBgColor;
    private double? _originalLineWidthPoints;
    private ColorSpec? _originalLineColor;

    // Snapshot values before editing so "Cancel" can restore them.
    private (string Name, string AltText, Emu X, Emu Y, Emu Width, Emu Height, double Rotation,
             bool FlipH, bool FlipV, bool Hidden, bool Decorative,
             FillType FillType, LineStyle LineStyle,
             string HyperlinkUrl)? _snapshot;

    protected override void OnParametersSet()
    {
        _name = Shape.Name;
        _altText = Shape.AltText ?? string.Empty;
        _x = Shape.X.ToInches();
        _y = Shape.Y.ToInches();
        _width = Shape.Width.ToInches();
        _height = Shape.Height.ToInches();
        _rotation = Shape.RotationDegrees;
        _flipH = Shape.FlipHorizontal;
        _flipV = Shape.FlipVertical;
        _hidden = Shape.IsHidden;
        _decorative = Shape.IsDecorative;
        _fillType = Shape.Fill.Type;
        _fillHex = XlsxColor.ToHex(Shape.Fill.Solid?.Color);
        _fgHex = XlsxColor.ToHex(Shape.Fill.Pattern?.ForegroundColor);
        _bgHex = XlsxColor.ToHex(Shape.Fill.Pattern?.BackgroundColor);
        _lineStyle = Shape.Line.Fill is { } ln
            ? (ln.Solid?.Color is not null ? LineStyle.Single : LineStyle.NoLine)
            : LineStyle.NoLine;
        _lineColor = XlsxColor.ToHex(Shape.Line.Fill?.Solid?.Color);
        _originalLineWidthPoints = Shape.Line.WidthPoints;
        _originalLineColor = Shape.Line.Fill?.Solid?.Color;
        _originalFillType = Shape.Fill.Type;
        _originalFillColor = Shape.Fill.Solid?.Color;
        _originalFillFgColor = Shape.Fill.Pattern?.ForegroundColor;
        _originalFillBgColor = Shape.Fill.Pattern?.BackgroundColor;
        _shadow = Shape.Effects.OuterShadow is not null;
        _glow = Shape.Effects.Glow is not null;
        _reflection = Shape.Effects.Reflection is not null;
        _originalShadow = _shadow;
        _originalGlow = _glow;
        _originalReflection = _reflection;
        _hyperlinkUrl = Shape.ClickAction?.Url ?? string.Empty;

        _snapshot = (_name, _altText, Shape.X, Shape.Y, Shape.Width, Shape.Height, _rotation,
                     _flipH, _flipV, _hidden, _decorative,
                     _fillType, _lineStyle,
                     _hyperlinkUrl);
    }

    private void Apply()
    {
        Shape.Name = _name;
        Shape.AltText = _altText;
        Shape.X = Emu.FromInches(_x);
        Shape.Y = Emu.FromInches(_y);
        Shape.Width = Emu.FromInches(_width);
        Shape.Height = Emu.FromInches(_height);
        Shape.RotationDegrees = _rotation;
        Shape.FlipHorizontal = _flipH;
        Shape.FlipVertical = _flipV;
        Shape.IsHidden = _hidden;
        Shape.IsDecorative = _decorative;
        Shape.Fill.SetSolid(XlsxColor.FromHex(_fillHex));
        if (Shape.Fill.Pattern is { } pf)
        {
            pf.ForegroundColor = XlsxColor.FromHex(_fgHex);
            pf.BackgroundColor = XlsxColor.FromHex(_bgHex);
        }
        if (_lineStyle != LineStyle.NoLine)
        {
            Shape.Line.SetSolid(XlsxColor.FromHex(_lineColor), _lineWidth);
        }
        else
        {
            Shape.Line.SetNone();
        }
        Shape.ClickAction = string.IsNullOrEmpty(_hyperlinkUrl) ? null : HyperlinkAction.ToUrl(_hyperlinkUrl);
        Shape.Effects.OuterShadow = _shadow ? new OuterShadowEffect() : null;
        Shape.Effects.Glow = _glow ? new GlowEffect() : null;
        Shape.Effects.Reflection = _reflection ? new ReflectionEffect() : null;
        OnChanged();
    }

    private void Cancel()
    {
        if (_snapshot is { } snap)
        {
            Shape.Name = snap.Name;
            Shape.AltText = snap.AltText;
            Shape.X = snap.X;
            Shape.Y = snap.Y;
            Shape.Width = snap.Width;
            Shape.Height = snap.Height;
            Shape.RotationDegrees = snap.Rotation;
            Shape.FlipHorizontal = snap.FlipH;
            Shape.FlipVertical = snap.FlipV;
            Shape.IsHidden = snap.Hidden;
            Shape.IsDecorative = snap.Decorative;
            // Restore Fill (FillFormat is read-only on Shape; restore its properties).
            if (snap.FillType == FillType.None)
            {
                Shape.Fill.SetNone();
            }
            else if (snap.FillType == FillType.Solid && _originalFillColor is not null)
            {
                Shape.Fill.SetSolid(_originalFillColor ?? ColorSpec.FromRgb(0, 0, 0));
            }
            else if (snap.FillType == FillType.Pattern)
            {
                Shape.Fill.SetSolid(_originalFillFgColor ?? ColorSpec.FromRgb(0, 0, 0));
                if (Shape.Fill.Pattern is { } pf)
                {
                    pf.ForegroundColor = _originalFillFgColor ?? ColorSpec.FromRgb(0, 0, 0);
                    pf.BackgroundColor = _originalFillBgColor ?? ColorSpec.FromRgb(0xFF, 0xFF, 0xFF);
                }
            }
            // Restore Line (LineFormat is read-only on Shape; restore its properties).
            if (snap.LineStyle == LineStyle.NoLine)
            {
                Shape.Line.SetNone();
            }
            else if (_originalLineColor is { } lc && _originalLineWidthPoints is { } wp)
            {
                Shape.Line.SetSolid(lc, wp);
            }
            // Restore effects to their original state.
            Shape.Effects.OuterShadow = _originalShadow ? new OuterShadowEffect() : null;
            Shape.Effects.Glow = _originalGlow ? new GlowEffect() : null;
            Shape.Effects.Reflection = _originalReflection ? new ReflectionEffect() : null;
        }
        OnChanged();
    }
}
