@inject IDialogService Dialogs
@inject ISnackbar Snackbar
@inject IUserFeedback Feedback
@inject IJSRuntime JS
@using System.Text
@using Unchained.Ooxml
@using Unchained.Pptx.Engine
@using Unchained.Pptx.Export
@using Unchained.Pptx.Models.Shapes
@using Unchained.Pptx.Shapes
@using Unchained.Pptx.Slides
@using Unchained.Studio.Infrastructure
@implements IAsyncDisposable

<div class="playboard-container">
    <!-- TOP TOOLBAR -->
    <div class="playboard-toolbar">
        <MudText Typo="Typo.subtitle2" Class="mr-2">@_slideName</MudText>
        <MudSpacer/>
        <MudMenu Label="Insert" StartIcon="@Icons.Material.Outlined.Add" Size="Size.Small" Dense="true">
            <ChildContent>
                <MudMenuItem Icon="@Icons.Material.Outlined.TextFields" OnClick="AddTextBox">TextBox</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.SquareFoot" OnClick="OpenShapeAddDialog">AutoShape</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.Image" OnClick="OpenPicturePicker">Picture</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.TableChart" OnClick="OpenTableDialog">Table</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.BarChart" OnClick="OpenChartDialog">Chart</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.Directions" OnClick="AddConnector">Connector</MudMenuItem>
            </ChildContent>
        </MudMenu>
        <MudDivider Vertical="true"/>
        <MudTooltip Text="Zoom out">
            <MudIconButton Icon="@Icons.Material.Outlined.ZoomOut" Size="Size.Small" OnClick="() => ZoomTo(Math.Max(0.25, _zoom - 0.25))"/>
        </MudTooltip>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@ZoomPercent%</MudChip>
        <MudTooltip Text="Zoom in">
            <MudIconButton Icon="@Icons.Material.Outlined.ZoomIn" Size="Size.Small" OnClick="() => ZoomTo(Math.Min(4.0, _zoom + 0.25))"/>
        </MudTooltip>
        <MudDivider Vertical="true"/>
        <MudTooltip Text="Transitions">
            <MudIconButton Icon="@Icons.Material.Outlined.AutoAwesome" Size="Size.Small" OnClick="OpenTransitions"/>
        </MudTooltip>
        <MudTooltip Text="Master slides">
            <MudIconButton Icon="@Icons.Material.Outlined.ViewComfy" Size="Size.Small" OnClick="OpenMasters"/>
        </MudTooltip>
        <MudTooltip Text="Slide properties">
            <MudIconButton Icon="@Icons.Material.Outlined.Settings" Size="Size.Small" OnClick="OpenSlideProps"/>
        </MudTooltip>
        <MudDivider Vertical="true"/>
        <MudTooltip Text="@(_showProperties ? "Hide shape properties" : "Show shape properties")">
            <MudToggleIconButton @bind-Toggled="_showProperties"
                                 Icon="@Icons.Material.Outlined.Tune"
                                 ToggledIcon="@Icons.Material.Filled.Tune"
                                 Color="Color.Default"
                                 ToggledColor="Color.Primary"
                                 Size="Size.Small"/>
        </MudTooltip>
    </div>

    <!-- MAIN AREA: canvas + properties panel -->
    <div class="playboard-body">
        <!-- SLIDE CANVAS -->
        <div class="playboard-canvas" @onwheel="OnWheel" @onkeydown="OnKeyDown">
            @if (_renderError != null)
            {
                <MudAlert Severity="Severity.Error" Class="playboard-error">
                    @(_renderError)
                </MudAlert>
            }
            @if (_slideSvg is not null && _renderError is null)
            {
                <div class="playboard-image-wrap" @ref="_pickerHost" style="transform:scale(@_zoom);transform-origin:top center;width:@(_slideWidth)px;height:@(_slideHeight)px;">
                    <div class="playboard-svg" style="width:@(_slideWidth)px;height:@(_slideHeight)px;">
                        @((MarkupString)_slideSvg)
                    </div>

                    @* Selection overlay — click-through except the selected shape's box, so the SVG
                       underneath receives the pointerdown that the JS picker hit-tests. *@
                    <div class="playboard-overlay" style="width:@(_slideWidth)px;height:@(_slideHeight)px;pointer-events:none;">
                        @if (SelectedShape is { } sel && Slide is not null && Slide.Shapes.Contains(sel))
                        {
                            <div class="playboard-shape playboard-shape--selected"
                                 style="@ShapeStyle(sel)"
                                 @onpointerdown="e => OnShapePointerDown(sel, e)"
                                 @onpointermove="OnPointerMove"
                                 @onpointerup="OnPointerUp"
                                 @ondblclick="() => OnShapeDoubleClick(sel)">
                                @foreach (var handle in _handles)
                                {
                                    <div class="@($"playboard-handle playboard-handle--{handle.Kind.ToString().ToLower()}")"
                                         style="@HandleStyle(handle, sel)"
                                         @onpointerdown="e => OnHandlePointerDown(handle, e)"
                                         @onpointerdown:stopPropagation="true">
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @* Full-cover capture layer — only present while dragging/resizing so pointer-move
               events (and the server round-trips they cause) never fire when idle. *@
            @if (State.IsDragging || State.IsResizing)
            {
                <div class="playboard-capture"
                     @onpointermove="OnPointerMove"
                     @onpointerup="OnPointerUp"
                     @onpointerleave="OnPointerUp">
                </div>
            }
        </div>

        <!-- PROPERTIES PANEL (optional — summoned via the toolbar toggle or the button below) -->
        @if (_showProperties)
        {
            <div class="playboard-properties">
                <div class="playboard-properties-header">
                    <MudText Typo="Typo.subtitle2">Shape properties</MudText>
                    <MudSpacer/>
                    <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                   OnClick="@(() => _showProperties = false)" title="Close"/>
                </div>
                @if (SelectedShape is not null)
                {
                    <ShapePropertiesPanel Shape="SelectedShape"
                                          OnChanged="OnShapeChanged"
                                          OnDelete="DeleteSelected"/>
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="pa-4" Style="opacity:.5;text-align:center;margin-top:32px;">
                        Select a shape on the slide to edit its properties.
                    </MudText>
                }
            </div>
        }
    </div>

    @* Floating summon button — appears when a shape is selected but the panel is hidden. *@
    @if (SelectedShape is not null && !_showProperties)
    {
        <MudButton Class="playboard-props-fab" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Outlined.Tune"
                   OnClick="@(() => _showProperties = true)">
            Edit properties
        </MudButton>
    }
</div>

@code {

    [Parameter]
    public PresentationDocument Document { get; set; } = null!;

    [Parameter]
    public Slide? Slide { get; set; }

    [Parameter]
    public SlidePlayboardState State { get; set; } = null!;

    [Parameter]
    public Func<Task>? OnDirty { get; set; }

    /// <summary>
    ///     Font names that may have fallen back (not embedded and not in a safe whitelist).
    ///     The parent component (PptxInfoPanel) displays these.
    /// </summary>
    [Parameter]
    public IReadOnlyList<string>? FontWarnings { get; set; }

    [Parameter]
    public Action<IReadOnlyList<string>>? OnFontWarnings { get; set; }

    private string _slideName = string.Empty;
    private string? _slideSvg;
    private int _slideWidth;
    private int _slideHeight;
    private string? _renderError;
    private double _zoom;
    private readonly List<ResizeHandle> _handles = Enum.GetValues<ResizeHandleKind>().Select(static k => new ResizeHandle(k, null!)).ToList();

    private string ZoomPercent => ((int)(_zoom * 100)).ToString();
    private Shape? SelectedShape => State.SelectedShape;

    private bool _dirtyWired;
    private bool _showProperties;
    private Slide? _renderedSlide;
    private ElementReference _pickerHost;
    private DotNetObjectReference<SlidePlayboard>? _selfRef;
    private bool _pickerAttached;

    protected override void OnParametersSet()
    {
        // Bridge the state's Dirty event to the OnDirty callback so edits (drag, resize, format,
        // add/delete) flow up to the tab → MarkDirty, making them downloadable via live serialize.
        if (!_dirtyWired)
        {
            State.Dirty += HandleDirty;
            _dirtyWired = true;
        }

        // The shown slide changed (navigation) — re-render it and drop any stale selection.
        if (!ReferenceEquals(_renderedSlide, Slide))
        {
            _renderedSlide = Slide;
            State.ClearSelection();
        }

        _slideName = Slide?.Name ?? "Slide";
        _zoom = State.Zoom;
        RenderSlideSync();
    }

    // Attach the JS shape-picker once the slide host is in the DOM. The listener is delegated on
    // the (stable) host element, so it survives SVG re-renders and only needs attaching once.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pickerAttached || _slideSvg is null)
            return;

        _selfRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("unchainedStudio.attachShapePicker", _pickerHost, _selfRef);
        _pickerAttached = true;
    }

    // Called from JS with the data-shape-index of the painted shape under the pointer (-1 = none).
    [JSInvokable]
    public Task SelectShapeByIndex(int index)
    {
        if (Slide is null)
            return Task.CompletedTask;

        if (index < 0 || index >= Slide.Shapes.Count)
            State.ClearSelection();
        else
            State.Select(Slide.Shapes[index]);

        return InvokeAsync(StateHasChanged);
    }

    private void HandleDirty()
    {
        if (OnDirty is not null)
            _ = OnDirty.Invoke();
    }

    public async ValueTask DisposeAsync()
    {
        if (_dirtyWired)
            State.Dirty -= HandleDirty;

        if (_pickerAttached)
        {
            // ReSharper disable once EmptyGeneralCatchClause
            try { await JS.InvokeVoidAsync("unchainedStudio.detachShapePicker", _pickerHost); }
            catch
            {
                /* circuit already torn down — nothing to detach */
            }
        }

        _selfRef?.Dispose();
    }

    private void ZoomTo(double z)
    {
        _zoom = State.Zoom = Math.Round(z, 2);
        StateHasChanged();
    }

    private void RenderSlideSync()
    {
        if (Slide == null)
            return;

        try
        {
            _renderError = null;

            var slideSize = Document.SlideSize;
            // Overlay coordinate space is px@96; size the SVG container to match so the
            // shape hit-targets line up exactly with the rendered geometry.
            _slideWidth = (int)Math.Round(slideSize.Width.ToPixels(96));
            _slideHeight = (int)Math.Round(slideSize.Height.ToPixels(96));

            // Use the overload that resolves font-family, embeds fonts, and returns warnings.
            var fontScheme = Slide.Master.Theme.Fonts;
            var embeddedFonts = Document.Media.Fonts;
            var (svgBytes, warnings) = PptxToSvgWriter.WriteSlide(
                Slide,
                slideSize,
                new SvgSaveOptions { Responsive = true, AnnotateShapes = true, EmbedFonts = true },
                fontScheme,
                embeddedFonts
            );

            // Inline SVG inside HTML must start at <svg> — strip the XML prolog the writer emits.
            var svg = Encoding.UTF8.GetString(svgBytes);
            var svgStart = svg.IndexOf("<svg", StringComparison.Ordinal);
            _slideSvg = svgStart > 0 ? svg[svgStart..] : svg;

            // Notify the user about font substitutions.
            if (warnings.Count <= 0) return;

            var names = string.Join(", ", warnings.Take(10));
            Feedback.Error($"Some fonts in this slide may fall back: {names}{(warnings.Count > 10 ? $" (+{warnings.Count - 10} more)" : "")}");
            OnFontWarnings?.Invoke(warnings);
        }
        catch (Exception ex)
        {
            _renderError = $"Rendering failed: {ex.Message}";
            _slideSvg = null;
        }
    }

    private static string ShapeStyle(Shape shape)
    {
        var left = shape.X.ToPixels(96);
        var top = shape.Y.ToPixels(96);
        var width = shape.Width.ToPixels(96);
        var height = shape.Height.ToPixels(96);
        return $"left:{left:0}px;top:{top:0}px;width:{width:0}px;height:{height:0}px;";
    }

    // Handles are children of the (absolutely-positioned) shape div, so their offsets are
    // relative to the shape box — NOT the overlay. Coordinates run 0..width / 0..height.
    private static string HandleStyle(ResizeHandle handle, Shape shape)
    {
        var width = shape.Width.ToPixels(96);
        var height = shape.Height.ToPixels(96);
        const double hs = 8.0;
        const double half = hs / 2;

        return handle.Kind switch
        {
            ResizeHandleKind.TopLeft => $"left:{-half:0}px;top:{-half:0}px;",
            ResizeHandleKind.Top => $"left:{(width / 2) - half:0}px;top:{-half:0}px;",
            ResizeHandleKind.TopRight => $"left:{width - half:0}px;top:{-half:0}px;",
            ResizeHandleKind.Right => $"left:{width - half:0}px;top:{(height / 2) - half:0}px;",
            ResizeHandleKind.BottomRight => $"left:{width - half:0}px;top:{height - half:0}px;",
            ResizeHandleKind.Bottom => $"left:{(width / 2) - half:0}px;top:{height - half:0}px;",
            ResizeHandleKind.BottomLeft => $"left:{-half:0}px;top:{height - half:0}px;",
            ResizeHandleKind.Left => $"left:{-half:0}px;top:{(height / 2) - half:0}px;",
            _ => string.Empty
        };
    }

    // A pointer is pressed on a shape/handle but hasn't yet moved past the drag threshold.
    // Until it does, a release is treated as a plain click (select only) — this keeps
    // double-click-to-edit working and avoids committing a no-op edit on every click.
    private bool _pressed;
    private ResizeHandle? _pressedHandle; // non-null ⇒ resize; null ⇒ move
    private bool _moved;
    private const double DragThresholdPx = 3.0;

    // Primary-button press on a shape selects it and arms a potential move-drag.
    private void OnShapePointerDown(Shape shape, MouseEventArgs e)
    {
        if (e.Button != 0) return;

        State.Select(shape);
        _pressed = true;
        _pressedHandle = null;
        _moved = false;
        State.DragStart = (e.ClientX, e.ClientY);
        State.DragOrigPos = (shape.X, shape.Y);
        StateHasChanged();
    }

    // Press on a handle is an unambiguous resize (no click/dblclick to disambiguate), so the
    // capture layer is shown immediately — that way dragging a handle outward, away from the
    // shape body, is still tracked. (pointerdown:stopPropagation in markup keeps this from also
    // arming a move-drag on the shape body.)
    private void OnHandlePointerDown(ResizeHandle handle, MouseEventArgs e)
    {
        if (SelectedShape is null || e.Button != 0) return;

        _pressed = true;
        _pressedHandle = handle;
        _moved = false;
        State.IsResizing = true;
        State.ActiveHandle = handle;
        State.DragStart = (e.ClientX, e.ClientY);
        State.DragOrigPos = (SelectedShape.X, SelectedShape.Y);
        State.DragOrigSize = (SelectedShape.Width, SelectedShape.Height);
        StateHasChanged();
    }

    // Live drag/resize. Before the threshold is crossed nothing happens (so a click stays a click);
    // once crossed, the drag is promoted (the capture layer appears) and the model is updated in
    // slide space. The SVG backdrop is regenerated once on release in OnPointerUp.
    private void OnPointerMove(PointerEventArgs e)
    {
        if (!_pressed || SelectedShape is null || State.DragStart is not { } start)
            return;

        // Client pixels → slide pixels (the slide is CSS-scaled by _zoom).
        var dxPx = (e.ClientX - start.MouseX) / _zoom;
        var dyPx = (e.ClientY - start.MouseY) / _zoom;

        if (!_moved)
        {
            // Move-drag requires a small threshold so a click stays a click (and dblclick works).
            // Resize already has its capture layer up (armed on handle pointerdown) → start at once.
            if (_pressedHandle is null && Math.Abs(dxPx) + Math.Abs(dyPx) < DragThresholdPx)
                return;

            _moved = true;
            if (_pressedHandle is null)
                State.IsDragging = true;
        }

        var dx = Emu.FromPixels(dxPx, 96);
        var dy = Emu.FromPixels(dyPx, 96);

        // ReSharper disable once ConvertIfStatementToSwitchStatement
        if (State is { IsDragging: true, DragOrigPos: { } origin })
            (SelectedShape.X, SelectedShape.Y) = (origin.OriginalX + dx, origin.OriginalY + dy);
        else if (State is { IsResizing: true, ActiveHandle: { } handle, DragOrigPos: { } pos, DragOrigSize: { } size })
            ApplyResize(handle.Kind, pos, size, dx, dy);

        StateHasChanged();
    }

    private void OnPointerUp(PointerEventArgs e)
    {
        if (!_pressed) return;

        var committed = _moved;
        _pressed = false;
        _moved = false;
        _pressedHandle = null;
        State.IsDragging = false;
        State.IsResizing = false;
        State.ActiveHandle = null;
        State.DragStart = null;

        // Only a real drag/resize commits: regenerate the backdrop and propagate dirty
        // (→ RefreshAsync → downloadable bytes). A plain click just keeps the selection.
        if (committed)
        {
            RenderSlideSync();
            State.InvokeDirty();
        }

        StateHasChanged();
    }

    // Adjusts position/size for the active handle, keeping each axis at a sensible minimum and
    // pinning the opposite edge when a left/top handle hits that minimum.
    private void ApplyResize(
        ResizeHandleKind kind,
        (Emu OriginalX, Emu OriginalY) pos,
        (Emu OrigWidth, Emu OrigHeight) size,
        Emu dx,
        Emu dy
    )
    {
        if (SelectedShape is null) return;

        var minimum = Emu.FromInches(0.1);
        var left = kind is ResizeHandleKind.Left or ResizeHandleKind.TopLeft or ResizeHandleKind.BottomLeft;
        var right = kind is ResizeHandleKind.Right or ResizeHandleKind.TopRight or ResizeHandleKind.BottomRight;
        var top = kind is ResizeHandleKind.Top or ResizeHandleKind.TopLeft or ResizeHandleKind.TopRight;
        var bottom = kind is ResizeHandleKind.Bottom or ResizeHandleKind.BottomLeft or ResizeHandleKind.BottomRight;

        var x = pos.OriginalX;
        var y = pos.OriginalY;
        var width = size.OrigWidth;
        var height = size.OrigHeight;

        if (left)
        {
            var newWidth = size.OrigWidth - dx;
            if (newWidth.Value < minimum.Value) newWidth = minimum;
            x = pos.OriginalX + (size.OrigWidth - newWidth);
            width = newWidth;
        }
        else if (right)
        {
            width = size.OrigWidth + dx;
            if (width.Value < minimum.Value) width = minimum;
        }

        if (top)
        {
            var newHeight = size.OrigHeight - dy;
            if (newHeight.Value < minimum.Value) newHeight = minimum;
            y = pos.OriginalY + (size.OrigHeight - newHeight);
            height = newHeight;
        }
        else if (bottom)
        {
            height = size.OrigHeight + dy;
            if (height.Value < minimum.Value) height = minimum;
        }

        SelectedShape.X = x;
        SelectedShape.Y = y;
        SelectedShape.Width = width;
        SelectedShape.Height = height;
    }

    private async void OnShapeDoubleClick(Shape shape)
    {
        try
        {
            if (shape is not AutoShape { IsTextBox: true } autoShape) return;

            var text = autoShape.TextFrame.PlainText;
            var result = await Dialogs.ShowAsync<InlineTextEditDialog>(
                "Edit Text",
                new DialogParameters { { nameof(InlineTextEditDialog.CurrentText), text } },
                Small()
            );
            var outcome = await result.Result;
            if (outcome is not { Canceled: false, Data: string newText }) return;

            autoShape.TextFrame.PlainText = newText;
            RenderSlideSync();
            State.InvokeDirty();
        }
        catch (Exception)
        {
            // ignored
        }
    }

    private void OnWheel(WheelEventArgs e)
    {
        var delta = e.DeltaY > 0 ? -0.1 : 0.1;
        ZoomTo(Math.Clamp(_zoom + delta, 0.25, 4.0));
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (SelectedShape is null) return;

        switch (e.Key)
        {
            case "Delete":
            case "Backspace":
                DeleteSelected();
            break;
        }
    }

    private void DeleteSelected()
    {
        if (SelectedShape is null || Slide is null) return;

        Slide.Shapes.Remove(SelectedShape);
        State.ClearSelection();
        StateHasChanged();
        State.InvokeDirty();
    }

    private void OnShapeChanged()
    {
        RenderSlideSync();
        State.InvokeDirty();
    }

    // ── Shape addition ────────────────────────────────────────────────────

    private void AddTextBox()
    {
        if (Slide is null) return;

        var box = Slide.Shapes.AddTextBox(
            Emu.FromInches(1),
            Emu.FromInches(1),
            Emu.FromInches(4),
            Emu.FromInches(1),
            "Double-click to edit text"
        );
        State.OnShapeAdded(box);
    }

    private async void OpenShapeAddDialog()
    {
        try
        {
            var parameters = new DialogParameters
            {
                { nameof(ShapeAddDialog.Kind), ShapeAddKind.AutoShape },
                { nameof(ShapeAddDialog.Document), Document },
                { nameof(ShapeAddDialog.Slide), Slide },
                { nameof(ShapeAddDialog.OnInserted), EventCallback.Factory.Create<Shape>(this, OnShapeInserted) }
            };
            await Dialogs.ShowAsync<ShapeAddDialog>("Insert AutoShape", parameters, Large());
        }
        catch (Exception)
        {
            // ignored
        }
    }

    private void OnShapeInserted(Shape shape)
    {
        State.OnShapeAdded(shape);
        StateHasChanged();
    }

    private async void OpenPicturePicker()
    {
        try
        {
            var parameters = new DialogParameters
            {
                { nameof(PictureInsertDialog.Document), Document },
                { nameof(PictureInsertDialog.Slide), Slide },
                { nameof(PictureInsertDialog.OnInserted), EventCallback.Factory.Create<Shape>(this, OnShapeInserted) }
            };
            await Dialogs.ShowAsync<PictureInsertDialog>("Insert Picture", parameters, Small());
        }
        catch (Exception)
        {
            // ignored
        }
    }

    private async void OpenTableDialog()
    {
        try
        {
            var parameters = new DialogParameters
            {
                { nameof(ShapeAddDialog.Kind), ShapeAddKind.Table },
                { nameof(ShapeAddDialog.Document), Document },
                { nameof(ShapeAddDialog.Slide), Slide },
                { nameof(ShapeAddDialog.OnInserted), EventCallback.Factory.Create<Shape>(this, OnShapeInserted) }
            };
            await Dialogs.ShowAsync<ShapeAddDialog>("Insert Table", parameters, Small());
        }
        catch (Exception)
        {
            // ignored
        }
    }

    private void OpenChartDialog() =>
        Snackbar.Add("Chart insertion coming soon", Severity.Info);

    private void AddConnector()
    {
        if (Slide is null) return;

        var conn = Slide.Shapes.AddConnector(
            ConnectorType.Bent,
            Emu.FromInches(1),
            Emu.FromInches(1),
            Emu.FromInches(5),
            Emu.FromInches(5)
        );
        State.OnShapeAdded(conn);
    }

    // ── Dialogs ──────────────────────────────────────────────────────────

    private Task OpenTransitions()
    {
        var parameters = new DialogParameters
        {
            { nameof(TransitionsDialog.Slide), Slide },
            { nameof(TransitionsDialog.OnChanged), (Action)State.InvokeDirty } // dialog's OnChanged is an Action
        };
        return Dialogs.ShowAsync<TransitionsDialog>("Slide Transitions", parameters, Small());
    }

    private Task OpenMasters()
    {
        var parameters = new DialogParameters { { nameof(SlideMasterViewer.Document), Document } };
        return Dialogs.ShowAsync<SlideMasterViewer>("Master Slides", parameters, Wide());
    }

    private Task OpenSlideProps()
    {
        var parameters = new DialogParameters
        {
            { nameof(SlidePropertiesDialog.Document), Document },
            { nameof(SlidePropertiesDialog.Slide), Slide },
            { nameof(SlidePropertiesDialog.OnChanged), EventCallback.Factory.Create(this, State.InvokeDirty) }
        };
        return Dialogs.ShowAsync<SlidePropertiesDialog>("Slide Properties", parameters, Small());
    }

    private static DialogOptions Small() => new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
    private static DialogOptions Large() => new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large, FullWidth = true };
    private static DialogOptions Wide() => new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
}
