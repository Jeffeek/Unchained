@using Unchained.Pptx.Engine

<MudPaper Class="pptx-info-panel pa-3" Elevation="0" Style="border:1px solid var(--mud-palette-divider);">
    <div class="d-flex align-center mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Class="mr-2" />
        <MudText Typo="Typo.subtitle2">Presentation</MudText>
        <MudSpacer />
        @if (Document.HasMacros)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                     Icon="@Icons.Material.Outlined.Code" Text="Macros" />
        }
    </div>

    <div class="pptx-info-grid">
        @foreach (var stat in _stats)
        {
            <div class="pptx-stat">
                <MudIcon Icon="@stat.Icon" Size="Size.Small" Class="pptx-stat-icon" />
                <div>
                    <div class="pptx-stat-value">@stat.Value</div>
                    <div class="pptx-stat-label">@stat.Label</div>
                </div>
            </div>
        }
    </div>

    @if (_props.Count > 0)
    {
        <MudDivider Class="my-2" />
        <div class="pptx-info-props">
            @foreach (var (label, value) in _props)
            {
                <div class="pptx-prop-row">
                    <span class="pptx-prop-label">@label</span>
                    <span class="pptx-prop-value">@value</span>
                </div>
            }
        </div>
    }
</MudPaper>

@code {
    [Parameter] public PresentationDocument Document { get; set; } = default!;

    private readonly List<(string Label, string Value, string Icon)> _stats = [];
    private readonly List<(string Label, string Value)> _props = [];

    protected override void OnParametersSet()
    {
        var hidden = Document.Slides.Count(s => s.IsHidden);
        var layouts = Document.Masters.Sum(m => m.Layouts.Count);
        var hyperlinks = Document.GetHyperlinks().Count();

        _stats.Clear();
        _stats.Add(("Slides", Document.Slides.Count.ToString(), Icons.Material.Outlined.Slideshow));
        _stats.Add(("Hidden", hidden.ToString(), Icons.Material.Outlined.VisibilityOff));
        _stats.Add(("Masters", Document.Masters.Count.ToString(), Icons.Material.Outlined.Dashboard));
        _stats.Add(("Layouts", layouts.ToString(), Icons.Material.Outlined.ViewQuilt));
        _stats.Add(("Sections", Document.Sections.Count.ToString(), Icons.Material.Outlined.Segment));
        _stats.Add(("Hyperlinks", hyperlinks.ToString(), Icons.Material.Outlined.Link));

        _props.Clear();
        var p = Document.Properties;
        if (!string.IsNullOrEmpty(p.Title)) _props.Add(("Title", p.Title!));
        if (!string.IsNullOrEmpty(p.Author)) _props.Add(("Author", p.Author!));
        if (p.Created is { } created) _props.Add(("Created", created.LocalDateTime.ToString("g")));
        if (p.Modified is { } modified) _props.Add(("Modified", modified.LocalDateTime.ToString("g")));
    }
}
