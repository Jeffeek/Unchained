@page "/pptx"
@inject SessionStateService Session
@inject FileExportService Exporter
@inject IUserFeedback Feedback
@inject IStudioDialogs Dialogs
@using System.Text
@using Unchained.Pptx.Rendering.Engine
@using Unchained.Pptx.Rendering.Models
@using Unchained.Pptx.Slides
@using Unchained.Studio.Infrastructure
@implements IDisposable

<div class="studio-tab">
    @if (Session.Pptx is null)
    {
        <div class="drop-zone-page">
            <FileDropZone Title="Drop a PPTX here"
                          Subtitle="Supports PowerPoint .pptx (OOXML). Legacy binary .ppt is not supported."
                          Accept=".pptx,.ppt"
                          OnFileLoaded="LoadPptx"
                          OnError="Feedback.Error"/>
        </div>
    }
    else
    {
        var state = Session.Pptx;

        <div class="three-panel">
            <!-- LEFT: tree -->
            <div class="panel-tree">
                <DocumentTree Root="state.Tree"
                              SelectedNodeChanged="OnNodeSelected"
                              OnRefreshRequested="RefreshTree"/>
            </div>

            <!-- CENTRE: slide playboard -->
            <div class="panel-preview">
                @{
                    var slideCount = state.Document.Slides.Count;
                    var currentSlide = Math.Clamp(state.CurrentSlide, 1, Math.Max(1, slideCount));
                }

                <!-- Slide management bar -->
                <div class="pptx-slidebar">
                    <MudIconButton Icon="@Icons.Material.Outlined.ChevronLeft" Size="Size.Small" title="Previous slide"
                                   Disabled="@(currentSlide <= 1)"
                                   OnClick="() => GoToSlide(currentSlide - 1)"/>
                    <span class="pptx-slidebar-label">Slide @currentSlide / @slideCount</span>
                    <MudIconButton Icon="@Icons.Material.Outlined.ChevronRight" Size="Size.Small" title="Next slide"
                                   Disabled="@(currentSlide >= slideCount)"
                                   OnClick="() => GoToSlide(currentSlide + 1)"/>
                    <span class="pptx-slidebar-sep"></span>
                    <MudIconButton Icon="@Icons.Material.Outlined.AddBox" Size="Size.Small" Color="Color.Primary" title="Add slide"
                                   OnClick="AddSlide"/>
                    <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Size="Size.Small" Color="Color.Error" title="Delete slide"
                                   Disabled="@(slideCount <= 1)"
                                   OnClick="DeleteCurrentSlide"/>
                </div>

                @if (_showInfo)
                {
                    <div class="pptx-info-strip">
                        <PptxInfoPanel Document="state.Document" FontWarnings="[.._fontWarnings]"/>
                    </div>
                }
                @if (slideCount > 0)
                {
                    <SlidePlayboard Document="state.Document"
                                    Slide="state.Document.Slides[currentSlide - 1]"
                                    State="state.PlayboardState"
                                    OnDirty="OnPlayboardDirty"
                                    OnFontWarnings="OnFontWarnings"/>
                }
            </div>

            <!-- RIGHT: properties -->
            <div class="panel-properties">
                <PropertiesPanel Bag="_selectedProperties"/>
            </div>
        </div>

        <!-- BOTTOM: operations bar -->
        <div class="operations-bar">
            <div class="ops-group">
                <MudButton StartIcon="@Icons.Material.Outlined.FileDownload"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenExportDialog">
                    Export…
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Image"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="ExportCurrentSlideImage">
                    Slide PNG
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.FolderZip"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenExportZipDialog">
                    Slides ZIP…
                </MudButton>
            </div>
            <MudDivider Vertical="true" Class="ops-divider"/>
            <div class="ops-group">
                <MudButton StartIcon="@Icons.Material.Outlined.FindReplace"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenFindReplaceDialog">
                    Find &amp; Replace…
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Link"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="OpenHyperlinkDialog">
                    Hyperlinks…
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.TextFields"
                           Variant="Variant.Text" Size="Size.Small"
                           OnClick="ExtractText">
                    Extract text
                </MudButton>
                <MudToggleIconButton @bind-Toggled="_showInfo"
                                     Icon="@Icons.Material.Outlined.Info"
                                     ToggledIcon="@Icons.Material.Filled.Info"
                                     Size="Size.Small"
                                     title="Toggle presentation info"/>
            </div>
            <MudDivider Vertical="true" Class="ops-divider"/>
            <div class="ops-group ops-group--right">
                <MudButton StartIcon="@Icons.Material.Outlined.Download"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="DownloadDocument">
                    Download
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Close"
                           Variant="Variant.Text" Size="Size.Small"
                           Color="Color.Error"
                           OnClick="CloseDocument">
                    Close
                </MudButton>
            </div>
        </div>

        @if (_showTextPanel)
        {
            <div class="text-panel">
                <div class="text-panel-toolbar">
                    <MudText Typo="Typo.subtitle2">Extracted Text</MudText>
                    <MudSpacer/>
                    <MudIconButton Icon="@Icons.Material.Outlined.Download"
                                   Size="Size.Small"
                                   OnClick="DownloadText"
                                   title="Download as .txt"/>
                    <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                   Size="Size.Small"
                                   OnClick="() => _showTextPanel = false"/>
                </div>
                <textarea class="text-content" readonly>@_extractedText</textarea>
            </div>
        }
    }

    @if (_busy)
    {
        <div class="loading-overlay">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary"/>
            <MudText Typo="Typo.body1" Class="mt-3">@_busyMessage</MudText>
        </div>
    }
</div>

@code {
    private PropertyBag? _selectedProperties;
    private bool _busy;
    private string _busyMessage = string.Empty;
    private bool _showTextPanel;
    private string? _extractedText;
    private bool _showInfo;
    private readonly HashSet<string> _fontWarnings = new(StringComparer.OrdinalIgnoreCase);

    private BusyScope _busyScope = null!;

    protected override void OnInitialized() =>
        _busyScope = new BusyScope(msg =>
            {
                _busyMessage = msg ?? string.Empty;
                _busy = msg is not null;
                StateHasChanged();
            }
        );

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;

        if (Session.Pptx is not null)
            Session.Pptx.Refreshed += OnSessionRefreshed;
    }

    private void OnSessionRefreshed()
    {
        // Keep the active slide index valid after add/delete so the playboard never indexes past the end.
        if (Session.Pptx is { } state)
            state.CurrentSlide = Math.Clamp(state.CurrentSlide, 1, Math.Max(1, state.Document.Slides.Count));

        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (Session.Pptx is not null)
            Session.Pptx.Refreshed -= OnSessionRefreshed;
    }

    private async Task LoadPptx((byte[] Bytes, string FileName) file)
    {
        // Legacy binary .ppt (BIFF/OLE compound document) is not OOXML and not supported.
        if (file.FileName.EndsWith(".ppt", StringComparison.OrdinalIgnoreCase)
            && !file.FileName.EndsWith(".pptx", StringComparison.OrdinalIgnoreCase))
        {
            Feedback.Error("Legacy binary .ppt is not supported. Please convert it to .pptx and try again.");
            return;
        }

        try
        {
            using var _ = _busyScope.Begin("Loading PPTX…");

            if (Session.Pptx is not null)
                Session.Pptx.Refreshed -= OnSessionRefreshed;

            await Session.LoadPptxAsync(file.Bytes, file.FileName);

            if (Session.Pptx is not null)
                Session.Pptx.Refreshed += OnSessionRefreshed;

            Feedback.Info($"Loaded {file.FileName}");
        }
        catch (Exception ex)
        {
            Feedback.Error($"Failed to load PPTX: {ex.Message}");
        }
    }

    private void OnNodeSelected(TreeNode? node)
    {
        _selectedProperties = node is null ? null : PptxPropertyAdapter.Build(node);

        // Selecting a slide in the tree navigates the playboard to that slide.
        if (node is not { NodeType: TreeNodeType.Slide, Payload: Slide slide } || Session.Pptx is null)
            return;

        var slides = Session.Pptx.Document.Slides;
        for (var i = 0; i < slides.Count; i++)
        {
            if (!ReferenceEquals(slides[i], slide)) continue;

            NavigateToSlide(i + 1);
            break;
        }
    }

    // Rebuild the tree from the live model only — no serialize+reload round-trip, which would
    // push the model through the lossy SDK writer and degrade the document.
    private void RefreshTree() => Session.Pptx?.RebuildTree();

    // Unedited download returns the original bytes verbatim — a perfect round-trip with zero
    // fidelity loss. Only when the model has actually been edited do we re-serialize (SDK in-place
    // save, which preserves unmodelled parts but re-emits modelled content).
    private async Task DownloadDocument()
    {
        if (Session.Pptx is null)
            return;

        try
        {
            byte[] bytes;
            if (Session.Pptx.IsDirty)
            {
                using var ms = new MemoryStream();
                await Session.Pptx.Processor.SaveAsync(Session.Pptx.Document, ms, PptxSessionState.SaveWithEngine);
                bytes = ms.ToArray();
            }
            else
            {
                bytes = Session.Pptx.CurrentBytes;
            }

            await Exporter.TriggerDownloadAsync(
                bytes,
                Session.Pptx.FileName,
                "application/vnd.openxmlformats-officedocument.presentationml.presentation"
            );
        }
        catch (Exception ex)
        {
            Feedback.Error($"Download failed: {ex.Message}");
        }
    }

    private void ExtractText()
    {
        if (Session.Pptx is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Extracting text…");

            var sb = new StringBuilder();
            var slides = Session.Pptx.Document.Slides;
            for (var i = 0; i < slides.Count; i++)
            {
                sb.AppendLine($"─── Slide {i + 1} ───");
                sb.AppendLine(slides[i].GetAllText());
                sb.AppendLine();
            }

            _extractedText = sb.ToString();
            _showTextPanel = true;
        }
        catch (Exception ex)
        {
            Feedback.Error($"Text extraction failed: {ex.Message}");
        }
    }

    private async Task DownloadText()
    {
        if (_extractedText is null)
            return;

        try
        {
            await Exporter.TriggerDownloadAsync(
                Encoding.UTF8.GetBytes(_extractedText),
                Path.ChangeExtension(Session.Pptx?.FileName ?? "presentation", ".txt"),
                "text/plain"
            );
        }
        catch (Exception ex)
        {
            Feedback.Error($"Download failed: {ex.Message}");
        }
    }

    private async Task ExportCurrentSlideImage()
    {
        if (Session.Pptx is null)
            return;

        try
        {
            using var _ = _busyScope.Begin("Rendering slide…");

            var state = Session.Pptx;
            var index = Math.Clamp(state.CurrentSlide, 1, state.Document.Slides.Count) - 1;
            var slide = state.Document.Slides[index];
            var image = await SlideRenderer.RenderAsync(
                slide,
                state.Document.SlideSize,
                new RenderOptions { WidthPx = 1920, HeightPx = 1080 }
            );

            var baseName = Path.GetFileNameWithoutExtension(state.FileName);
            await Exporter.TriggerDownloadAsync(
                image.Data.ToArray(),
                $"{baseName}-slide{index + 1}.png",
                "image/png"
            );
        }
        catch (DllNotFoundException)
        {
            Feedback.Error("FreeType native library not found. Run scripts/FetchNatives/fetch-natives to enable rendering.");
        }
        catch (Exception ex)
        {
            Feedback.Error($"Slide export failed: {ex.Message}");
        }
    }

    private Task OpenExportZipDialog() =>
        Session.Pptx is null
            ? Task.CompletedTask
            : Dialogs.ShowVoidAsync<SlideExportDialog>(
                "Export Slides",
                p =>
                {
                    p[nameof(SlideExportDialog.Document)] = Session.Pptx.Document;
                    p[nameof(SlideExportDialog.FileName)] = Session.Pptx.FileName;
                    p[nameof(SlideExportDialog.CurrentSlide)] = Session.Pptx.CurrentSlide;
                }
            );

    private Task OpenExportDialog() =>
        Session.Pptx is null
            ? Task.CompletedTask
            : Dialogs.ShowVoidAsync<PptxExportDialog>(
              "Export Presentation",
              p =>
              {
                  p[nameof(PptxExportDialog.Processor)] = Session.Pptx!.Processor;
                  p[nameof(PptxExportDialog.Document)] = Session.Pptx.Document;
                  p[nameof(PptxExportDialog.FileName)] = Session.Pptx.FileName;
              }
            );

    private Task OpenFindReplaceDialog() =>
        Session.Pptx is null
            ? Task.CompletedTask
            : Dialogs.ShowVoidAsync<FindReplaceDialog>(
                "Find & Replace",
                p =>
                {
                    p[nameof(FindReplaceDialog.Document)] = Session.Pptx.Document;
                    p[nameof(FindReplaceDialog.OnReplaced)] = EventCallback.Factory.Create(this, RefreshTree);
                }
            );

    private Task OpenHyperlinkDialog() =>
        Session.Pptx is null
            ? Task.CompletedTask
            : Dialogs.ShowVoidAsync<HyperlinkBrowserDialog>(
                "Hyperlinks",
                p =>
                {
                    p[nameof(HyperlinkBrowserDialog.Document)] = Session.Pptx.Document;
                    p[nameof(HyperlinkBrowserDialog.OnNavigate)] = EventCallback.Factory.Create<int>(this, NavigateToSlide);
                }
            );

    private void NavigateToSlide(int slideNumber)
    {
        if (Session.Pptx is null)
            return;

        Session.Pptx.CurrentSlide = Math.Clamp(slideNumber, 1, Session.Pptx.Document.Slides.Count);
        StateHasChanged();
    }

    private void GoToSlide(int slideNumber) => NavigateToSlide(slideNumber);

    private void AddSlide()
    {
        if (Session.Pptx is not { } state)
            return;

        var layout = state.Document.Masters.FirstOrDefault()?.Layouts.FirstOrDefault();
        if (layout is null)
        {
            Feedback.Error("No slide layout available to base a new slide on.");
            return;
        }

        var slide = state.Document.Slides.AddBlank(layout);
        slide.Name = $"Slide {state.Document.Slides.Count}";
        state.CurrentSlide = state.Document.Slides.Count; // jump to the new slide
        state.MarkDirty();
    }

    private async Task DeleteCurrentSlide()
    {
        if (Session.Pptx is not { } state)
            return;

        if (state.Document.Slides.Count <= 1)
        {
            Feedback.Error("A presentation must keep at least one slide.");
            return;
        }

        var confirmed = await Dialogs.ShowMessageBoxAsync("Delete slide", "Delete this slide? This cannot be undone.", "Delete", "Cancel");
        if (confirmed != true)
            return;

        var index = Math.Clamp(state.CurrentSlide, 1, state.Document.Slides.Count) - 1;
        state.Document.Slides.RemoveAt(index);
        state.CurrentSlide = Math.Clamp(state.CurrentSlide, 1, state.Document.Slides.Count);
        state.MarkDirty();
    }


    private async Task CloseDocument()
    {
        if (Session.Pptx is not null)
            Session.Pptx.Refreshed -= OnSessionRefreshed;
        await Session.ClosePptxAsync();
        _selectedProperties = null;
        _showTextPanel = false;
        _extractedText = null;
    }

    // In-place edit: rebuild the tree and flag dirty WITHOUT reloading the document, so the
    // selected shape (and the rest of the model) keep their identity across edits. The download
    // serializes the live document, so changes are still saved.
    private Task OnPlayboardDirty()
    {
        Session.Pptx?.MarkDirty();
        return Task.CompletedTask;
    }

    private void OnFontWarnings(IReadOnlyList<string> warnings)
    {
        foreach (var w in warnings)
            _fontWarnings.Add(w);
    }
}
