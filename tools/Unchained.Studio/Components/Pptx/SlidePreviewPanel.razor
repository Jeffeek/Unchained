@using Unchained.Pptx.Engine
@using Unchained.Pptx.Rendering.Engine
@using Unchained.Pptx.Rendering.Models
@using Unchained.Pptx.Slides
@implements IDisposable

<div class="preview-panel">
    <div class="preview-toolbar">
        <MudIconButton Icon="@Icons.Material.Outlined.NavigateBefore"
                       Size="Size.Small"
                       Disabled="@(CurrentSlide <= 1)"
                       OnClick="PreviousSlide"
                       title="Previous slide (←)"/>
        <span class="preview-page-label">
            <MudText Typo="Typo.body2" Style="white-space:nowrap;">Slide</MudText>
            <input class="preview-page-input"
                   type="number"
                   min="1" max="@SlideCount"
                   value="@CurrentSlide"
                   @onchange="OnSlideInputChanged"/>
            <MudText Typo="Typo.body2" Style="white-space:nowrap;">/ @SlideCount</MudText>
        </span>
        <MudIconButton Icon="@Icons.Material.Outlined.NavigateNext"
                       Size="Size.Small"
                       Disabled="@(CurrentSlide >= SlideCount)"
                       OnClick="NextSlide"
                       title="Next slide (→)"/>

        <MudDivider Vertical="true" Class="mx-1" Style="height:24px;"/>

        <MudIconButton Icon="@Icons.Material.Outlined.ZoomOut" Size="Size.Small" OnClick="ZoomOut" title="Zoom out"/>
        <MudText Typo="Typo.caption" Class="mx-1" Style="min-width:36px;text-align:center;">@(_zoom)%</MudText>
        <MudIconButton Icon="@Icons.Material.Outlined.ZoomIn" Size="Size.Small" OnClick="ZoomIn" title="Zoom in"/>

        <MudSpacer/>

        @if (Slide is not null && Slide.IsHidden)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Text="Hidden"/>
        }
    </div>

    <div class="preview-canvas">
        @if (_busy)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Medium" Color="Color.Primary"/>
        }
        else if (_renderError is not null)
        {
            <MudAlert Severity="Severity.Warning" Class="ma-3">
                Slide rendering unavailable: @_renderError
            </MudAlert>
        }
        else if (_slideBytes is not null)
        {
            <img src="data:image/png;base64,@Convert.ToBase64String(_slideBytes)"
                 class="preview-page-img"
                 style="width:@(_zoom)%;"
                 alt="Slide @CurrentSlide"/>
        }
    </div>
</div>

@code {

    [Parameter]
    public PresentationDocument? Document { get; set; }

    [Parameter]
    public int CurrentSlide { get; set; } = 1;

    [Parameter]
    public EventCallback<int> CurrentSlideChanged { get; set; }

    private byte[]? _slideBytes;
    private string? _renderError;
    private bool _busy;
    private int _zoom = 75;
    private int _lastRendered = -1;
    private PresentationDocument? _lastDocument;

    private int SlideCount => Document?.Slides.Count ?? 0;

    private Slide? Slide =>
        Document is not null && CurrentSlide >= 1 && CurrentSlide <= SlideCount
            ? Document.Slides[CurrentSlide - 1]
            : null;

    protected override Task OnParametersSetAsync()
    {
        // Re-render when the document or selected slide changes.
        if (Document == _lastDocument && CurrentSlide == _lastRendered)
            return Task.CompletedTask;

        _lastDocument = Document;
        return RenderCurrentSlideAsync();
    }

    private async Task RenderCurrentSlideAsync()
    {
        var current = Slide;
        if (Document is null || current is null)
        {
            _slideBytes = null;
            return;
        }

        _busy = true;
        _renderError = null;
        StateHasChanged();

        try
        {
            var image = await SlideRenderer.RenderAsync(
                current,
                Document.SlideSize,
                new RenderOptions { WidthPx = 1280, HeightPx = 720 });
            _slideBytes = image.Data.ToArray();
            _lastRendered = CurrentSlide;
        }
        catch (DllNotFoundException)
        {
            // FreeType native binary not present — rendering needs scripts/FetchNatives.
            _renderError = "FreeType native library not found. Run scripts/FetchNatives/fetch-natives.";
            _slideBytes = null;
        }
        catch (Exception ex)
        {
            _renderError = ex.Message;
            _slideBytes = null;
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private Task PreviousSlide() => CurrentSlide <= 1 ? Task.CompletedTask : CurrentSlideChanged.InvokeAsync(CurrentSlide - 1);

    private Task NextSlide() => CurrentSlide >= SlideCount ? Task.CompletedTask : CurrentSlideChanged.InvokeAsync(CurrentSlide + 1);

    private Task OnSlideInputChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var n))
            return Task.CompletedTask;

        n = Math.Clamp(n, 1, Math.Max(1, SlideCount));
        return CurrentSlideChanged.InvokeAsync(n);
    }

    private void ZoomIn() => _zoom = Math.Min(200, _zoom + 25);
    private void ZoomOut() => _zoom = Math.Max(25, _zoom - 25);

    public void Dispose()
    {
        // No unmanaged resources held directly; slide bytes are GC-managed.
    }

}
