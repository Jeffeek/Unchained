@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject ThemeService ThemeSvc
@implements IDisposable

<MudThemeProvider Theme="ThemeSvc.Theme" IsDarkMode="ThemeSvc.IsDarkMode"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIcon Icon="@Icons.Material.Filled.AutoStories" Class="mr-2"/>
        <MudText Typo="Typo.h6" Class="mr-6">Unchained Studio</MudText>

        <nav class="studio-nav">
            <NavTab Label="Home" Icon="@Icons.Material.Outlined.Home" Path="/" Active="@IsActive("/")" OnNavigate="Navigate"/>
            <NavTab Label="PDF" Icon="@Icons.Material.Outlined.PictureAsPdf" Path="/pdf" Active="@IsActive("/pdf")" OnNavigate="Navigate"/>
            <NavTab Label="PPTX" Icon="@Icons.Material.Outlined.Slideshow" Path="/pptx" Active="@IsActive("/pptx")" OnNavigate="Navigate"/>
            <NavTab Label="DOCX" Icon="@Icons.Material.Outlined.Description" Disabled="true"/>
            <NavTab Label="XLSX" Icon="@Icons.Material.Outlined.TableChart" Disabled="true"/>
        </nav>

        <MudSpacer/>

        <MudTooltip Text="@(ThemeSvc.IsDarkMode ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton Icon="@(ThemeSvc.IsDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="ToggleTheme"/>
        </MudTooltip>
        <MudText Typo="Typo.caption" Class="mx-2" Style="opacity:0.7">
            v0.1.0
        </MudText>
        <MudTooltip Text="Documentation">
            <MudIconButton Icon="@Icons.Material.Outlined.Help"
                           Color="Color.Inherit"
                           Href="https://github.com/Jeffeek/Unchained"
                           Target="_blank"/>
        </MudTooltip>
    </MudAppBar>

    <MudMainContent Class="studio-main">
        <!-- ErrorBoundary: catches unhandled exceptions in the component tree.
             Without this, any throw anywhere disposes the Blazor circuit silently,
             global event listeners remain, and every subsequent click errors with
             "No interop methods are registered for renderer N". -->
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="pa-4">
                    <MudAlert Severity="Severity.Error" Class="mb-3">
                        <strong>Rendering error — circuit protected.</strong><br/>
                        @ex.Message
                    </MudAlert>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="RecoverFromError">
                        Recover
                    </MudButton>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>
</MudLayout>

@code {
    private ErrorBoundary? _errorBoundary;

    protected override void OnInitialized()
    {
        ThemeSvc.Changed += OnThemeChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override Task OnAfterRenderAsync(bool firstRender) => firstRender ? ThemeSvc.InitializeAsync() : Task.CompletedTask;

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private Task ToggleTheme() => ThemeSvc.ToggleAsync();

    private void RecoverFromError() => _errorBoundary?.Recover();

    private void Navigate(string path) => Nav.NavigateTo(path);

    private bool IsActive(string path)
    {
        var relative = "/" + Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        if (relative == string.Empty) relative = "/";
        return relative == path;
    }

    public void Dispose()
    {
        ThemeSvc.Changed -= OnThemeChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

}
