@inherits LayoutComponentBase
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIcon Icon="@Icons.Material.Filled.AutoStories" Class="mr-2" />
        <MudText Typo="Typo.h6" Class="mr-4">Unchained Studio</MudText>

        <MudChip T="string" Text="PDF" Color="@ChipColor("/")" Size="Size.Small"
                 OnClick="@(() => Navigate("/"))" />
        <MudChip T="string" Text="PPTX" Color="@ChipColor("/pptx")" Size="Size.Small"
                 OnClick="@(() => Navigate("/pptx"))" />
        <MudChip T="string" Text="DOCX" Size="Size.Small" Disabled="true" />
        <MudChip T="string" Text="XLSX" Size="Size.Small" Disabled="true" />

        <MudSpacer />
        <MudText Typo="Typo.caption" Class="mr-2" Style="opacity:0.6">
            Unchained v0.1.0
        </MudText>
        <MudIconButton Icon="@Icons.Material.Outlined.Help"
                       Href="https://github.com/Jeffeek/Unchained"
                       Target="_blank"
                       Size="Size.Small"
                       title="Documentation" />
    </MudAppBar>

    <MudMainContent Class="studio-main">
        <!-- ErrorBoundary: catches unhandled exceptions in the component tree.
             Without this, any throw anywhere disposes the Blazor circuit silently,
             global event listeners remain, and every subsequent click errors with
             "No interop methods are registered for renderer N". -->
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="pa-4">
                    <MudAlert Severity="Severity.Error" Class="mb-3">
                        <strong>Rendering error — circuit protected.</strong><br />
                        @ex.Message
                    </MudAlert>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="RecoverFromError">
                        Recover
                    </MudButton>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>
</MudLayout>

@code {
    private ErrorBoundary? _errorBoundary;

    // Minimal, safe theme — use hex strings only, avoid Colors.* static
    // references that may behave differently across MudBlazor versions.
    private static readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary   = "#5C6BC0",
            Secondary = "#26A69A",
        }
    };

    private void RecoverFromError()
    {
        _errorBoundary?.Recover();
    }

    private void Navigate(string path) => Nav.NavigateTo(path);

    private Color ChipColor(string path)
    {
        var relative = "/" + Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        if (relative == string.Empty) relative = "/";
        return relative == path ? Color.Primary : Color.Default;
    }
}
