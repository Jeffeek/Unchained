@page "/"
@inject NavigationManager Nav

<div class="home-page">
    <div class="home-header">
        <div class="home-header-left">
            <MudText Typo="Typo.h4" Class="home-title">Unchained Studio</MudText>
        </div>
        <div class="home-version">v0.1.0</div>
    </div>

    <MudText Typo="Typo.body2" Class="home-tagline">
        A pure-managed document engine for PDF and Office formats.
    </MudText>

    <div class="home-badges">
        <span class="home-badge">.NET 8 / 9 / 10</span>
        <span class="home-badge">100% C#</span>
        <span class="home-badge">MIT-friendly stack</span>
    </div>

    <div class="home-body">
        <div class="home-formats">
            @foreach (var f in _formats)
            {
                <div class="home-format-card @(f.Enabled ? "" : "home-format-card--soon")"
                     @onclick="@(() => OpenFormat(f))">
                    <div class="home-format-head">
                        <MudIcon Icon="@f.Icon" Class="home-format-icon"/>
                        <MudText Typo="Typo.h6">@f.Name</MudText>
                        @if (!f.Enabled)
                        {
                            <span class="home-format-soon">coming soon</span>
                        }
                    </div>
                    <MudText Typo="Typo.caption" Class="home-format-tagline">@f.Tagline</MudText>
                </div>
            }
        </div>

        <div class="home-capabilities">
            <MudText Typo="Typo.subtitle1" Class="home-caps-heading">Engine Capabilities</MudText>
            <div class="home-cap-list">
                @foreach (var cap in _capabilities)
                {
                    <div class="home-cap-item">
                        <MudIcon Icon="@cap.Icon" Size="Size.Small" Class="home-cap-icon"/>
                        <div>
                            <div class="home-cap-name">@cap.Name</div>
                            <div class="home-cap-desc">@cap.Desc</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly List<FormatCard> _formats =
    [
        new("PDF", "Read, render, edit, convert", Icons.Material.Outlined.PictureAsPdf, true, "/pdf"),
        new("PPTX", "PowerPoint presentations", Icons.Material.Outlined.Slideshow, true, "/pptx"),
        new("DOCX", "Word documents", Icons.Material.Outlined.Description, false, "/docx"),
        new("XLSX", "Excel workbooks", Icons.Material.Outlined.TableChart, true, "/xlsx")
    ];

    private readonly List<Capability> _capabilities =
    [
        new("Render", "FreeType2 + HarfBuzz text shaping", Icons.Material.Outlined.Image),
        new("Convert", "PDF · HTML5 · SVG · ODP export", Icons.Material.Outlined.SwapHoriz),
        new("Edit", "Find/replace, hyperlinks, merge/split", Icons.Material.Outlined.Edit),
        new("Secure", "AES-256 encryption, signatures", Icons.Material.Outlined.Lock),
        new("Validate", "PDF/A & PDF/UA conformance", Icons.Material.Outlined.VerifiedUser),
        new("Inspect", "Full document object model", Icons.Material.Outlined.AccountTree)
    ];

    private void OpenFormat(FormatCard f)
    {
        if (f.Enabled)
            Nav.NavigateTo(f.Route);
    }

}
