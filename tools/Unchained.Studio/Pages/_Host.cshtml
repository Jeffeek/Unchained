@* ReSharper disable once ArrangeAttributes *@
@page "/"
@using Unchained.Studio.Components
@namespace Unchained.Studio.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Unchained Studio</title>
    <base href="/"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet"/>
    @* ReSharper disable Html.PathError *@
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet"/>
    <link href="css/app.css" rel="stylesheet"/>
    @* ReSharper restore Html.PathError *@
</head>
<body>
<component type="typeof(App)" render-mode="Server"/>

<script src="js/interop.js"></script>
@* ReSharper disable Html.PathError *@
<script src="https://code.highcharts.com/highcharts.js"></script>
<script src="https://code.highcharts.com/highcharts-more.js"></script>
<script src="https://code.highcharts.com/modules/drilldown.js"></script>
<script src="https://code.highcharts.com/modules/annotations.js"></script>
<script src="_content/MudBlazor/MudBlazor.min.js"></script>
<script src="_framework/blazor.server.js"></script>
@* ReSharper restore Html.PathError *@

<script>
        // Catch "No interop methods are registered for renderer N" errors.
        // Per https://github.com/dotnet/aspnetcore/issues/56813, this is a known
        // Blazor race condition: when the circuit closes, global event listeners
        // are not cleaned up, so the next interaction fires through a stale bridge.
        // The ErrorBoundary in MainLayout.razor prevents the circuit from closing
        // due to unhandled exceptions. This handler logs the root cause so it
        // becomes visible instead of silently breaking the UI.
        window.addEventListener('error', function (e) {
            if (e.message && e.message.includes('No interop methods are registered')) {
                console.error(
                    '[Unchained Studio] Blazor circuit interop error. ' +
                    'The circuit may have closed due to an unhandled exception. ' +
                    'Check server logs for the root cause. ' +
                    'The Blazor reconnect UI will appear shortly.',
                    e
                );
                // Prevent the error from surfacing as an uncaught JS exception.
                // Blazor's own reconnect mechanism will handle recovery.
                e.preventDefault();
            }
        });

        // Log all unhandled promise rejections so the root cause is visible.
        window.addEventListener('unhandledrejection', function (e) {
            if (e.reason && String(e.reason).includes('interop')) {
                console.error('[Unchained Studio] Unhandled interop rejection:', e.reason);
            }
        });
    </script>
</body>
</html>
